@using SENSEI.DOMAIN
@using core_web.Helpers
@model Course

@{
    ViewData["Title"] = "Lesson";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Lessons</h1>
            <p class="text-muted small mb-0">Define and manage the core curriculum across all courses.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewLesson" data-action-url="/AdminPortal/Lesson/Create">
            <i class="fas fa-plus me-2"></i> New Lesson
        </button>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4 g-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid var(--sensei-red) !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-primary text-primary rounded-circle p-2 me-3">
                        <i data-feather="book-open" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Total Lessons</h6>
                        <h4 class="fw-900 mb-0" id="stat-total-lessons">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #03a9f3 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-info text-info rounded-circle p-2 me-3">
                        <i data-feather="grid" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Courses Covered</h6>
                        <h4 class="fw-900 mb-0" id="stat-courses">...</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
        <div class="card-body p-4">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-filter"></i>
                    </div>
                </div>
                <div class="col">
                    <h5 class="mb-0 fw-800">Curriculum Filter</h5>
                    <p class="text-muted small mb-0">Filter lessons by their associated course.</p>
                </div>
                <div class="col-md-4">
                    <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-white"></select>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="card-title mb-0 fw-800">Course Curriculum</h5>
                </div>
                <div class="card-body p-0">
                    <div id="LessonTableContent" class="table-responsive">
                        <table id="LessonDataTable" class="table table-hover align-middle mb-0 w-100">
                            <thead class="bg-light">
                                <tr>
                                    <th style="display:none;">ID</th>
                                    <th class="ps-4" style="width: 40px;"></th>
                                    <th>Course</th>
                                    <th>Lesson Title</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("LessonOffCanvas", "Lesson", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/lesson-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                var courseId = $(this).val();

                console.log(courseId);

                loadLessons();
            });


            $.getJSON('/AdminPortal/Lesson/GetCourseListJsonResult', function (data) {

                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();

                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            loadLessons();

        });

        function loadLessons() {

            if ($.fn.DataTable.isDataTable('#LessonDataTable')) {
                $('#LessonDataTable').DataTable().clear().destroy();
                $('#LessonDataTable tbody').empty();
            }

            $('#LessonDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                order: [[0, "desc"]], // New Lessons First
                columnDefs: [
                    { targets: 0, visible: false }, // Hide ID
                    { targets: 1, className: 'noVis' },
                    { width: 25, targets: 1, orderable: false },
                ],
                dom:
                    "<'row mb-3'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row mt-3'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/Lesson/ListOfLessons',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                    }
                },
                columns: [
                    { data: 'lessonId', name: 'lessonId' },
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        className: "text-center",
                        render: function (data, type, row) {
                            var editUrl = `/AdminPortal/Lesson/Edit/?q=${row.encryptedKey}`;
                            var deleteUrl = `/AdminPortal/Lesson/Delete/?q=${row.encryptedKey}`;

                            return `
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-soft-primary p-1 px-2 rounded-pill edit-lesson" data-action-url="${editUrl}" title="Edit Lesson">
                                        <i data-feather="edit" style="width: 14px; height: 14px;"></i>
                                    </button>
                                    <button class="btn btn-sm btn-soft-danger p-1 px-2 rounded-pill delete-lesson" data-action-url="${deleteUrl}" data-action-parameter="${row.lessonName}" title="Delete Lesson">
                                        <i data-feather="trash-2" style="width: 14px; height: 14px;"></i>
                                    </button>
                                </div>`;
                        }
                    },
                    { data: 'course.courseName', name:'course.courseName', render: function(d) { return `<span class="fw-bold text-dark">${d||'—'}</span>`; } },
                    { data: 'lessonName', name:'lessonName', render: function(d) { return `<div class="fw-800 text-primary" style="font-size: 0.95rem;">${d||'No Title'}</div>`; } },
                    { data: 'description', name:'description', render: function(d) { return `<div class="text-secondary" style="font-size: 0.9rem; max-width: 400px; white-space: normal; line-height: 1.5;">${d||'—'}</div>`; } }
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }

                    // Calculate stats
                    var tableData = $('#LessonDataTable').DataTable().rows().data();
                    var total = tableData.length;
                    var courses = new Set();
                    tableData.each(function(row) {
                        if (row.course) courses.add(row.course.courseId);
                    });

                    $('#stat-total-lessons').text(total);
                    $('#stat-courses').text(courses.size || 0);

                    editLessonButton();
                    deleteLessonButton();
                }
            });

        }

    </script>

}
