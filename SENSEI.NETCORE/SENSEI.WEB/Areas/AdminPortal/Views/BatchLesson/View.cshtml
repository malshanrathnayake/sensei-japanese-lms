@using SENSEI.DOMAIN
@using core_web.Helpers
@using System.Web
@model BatchLesson

@{
    ViewData["Title"] = $"Lesson {Model?.Lesson?.LessonName}";
    string videoId = null;

    if (!string.IsNullOrWhiteSpace(Model.RecordingUrl))
    {
        var uri = new Uri(Model.RecordingUrl);
        videoId = HttpUtility.ParseQueryString(uri.Query).Get("v");
    }
}

<style>
    /* Improved Delete Button Styling */
    .btn-delete-ref {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: 1px solid transparent;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        margin-right: 12px;
    }

    .btn-delete-ref:hover {
        background-color: #dc3545;
        color: white;
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.2);
    }

    /* Custom Confirmation Modal */
    .confirm-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .confirm-modal-overlay.show {
        display: flex;
        opacity: 1;
    }

    .confirm-modal-card {
        background: white;
        border-radius: 20px;
        width: 90%;
        max-width: 400px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transform: scale(0.9);
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .confirm-modal-overlay.show .confirm-modal-card {
        transform: scale(1);
    }

    .modal-icon-wrapper {
        width: 64px;
        height: 64px;
        background: #fff5f5;
        color: #dc3545;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
    }

    .modal-title {
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 0.5rem;
    }

    .modal-text {
        color: #64748b;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
    }

    .btn-modal {
        flex: 1;
        padding: 0.75rem;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.2s;
        border: none;
    }

    .btn-modal-cancel {
        background: #f1f5f9;
        color: #475569;
    }

    .btn-modal-cancel:hover {
        background: #e2e8f0;
        color: #1e293b;
    }

    .btn-modal-delete {
        background: #dc3545;
        color: white;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.2);
    }

    .btn-modal-delete:hover {
        background: #bb2d3b;
        transform: translateY(-1px);
        box-shadow: 0 6px 15px rgba(220, 53, 69, 0.3);
    }
</style>

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">@Model?.Lesson?.LessonName</h1>

    </div>

    <div class="row">

        <div class="col-lg-8 col-md-12 col-sm-12">
            <div class="row">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">@Model.Description</h5>
                    </div>
                    <div class="card-body">

                        <div class="row">
                            <div class="player-wrapper">
                                <div id="player"></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="row">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Student Ratings</h5>
                    </div>
                    <div class="card-body">

                        <div id="ratingContent" class="table-responsive">

                            <table id="ratingDataTable" class="table table-hover align-middle mb-0 w-100">
                                <thead>
                                    <tr>
                                        <th>@Html.DisplayNameFor(m => m.BatchStudentLessonAccesses.FirstOrDefault().Student.IndexNumber)</th>
                                        <th>@Html.DisplayNameFor(m => m.BatchStudentLessonAccesses.FirstOrDefault().Student.StudentPopulatedName)</th>
                                        <th>@Html.DisplayNameFor(m => m.BatchStudentLessonAccesses.FirstOrDefault().Rating)</th>
                                        <th>@Html.DisplayNameFor(m => m.BatchStudentLessonAccesses.FirstOrDefault().Feedback)</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        var index = 1;
                                    }

                                    @foreach (var lessonAccess in Model.BatchStudentLessonAccesses.Where(e => !string.IsNullOrWhiteSpace(e.Feedback)))
                                    {
                                        <tr>
                                            <td>@lessonAccess.Student?.IndexNumber</td>
                                            <td>@lessonAccess.Student?.StudentPopulatedName</td>
                                            <td>
                                                @if (lessonAccess.Rating.HasValue)
                                                {
                                                    <div class="d-inline-flex align-items-center gap-1">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (i <= lessonAccess.Rating.Value)
                                                            {
                                                                <span style="color:#f5b301; font-size:18px;">&#9733;</span>
                                                            }
                                                            else
                                                            {
                                                                <span style="color:#d6d6d6; font-size:18px;">&#9733;</span>
                                                            }
                                                        }
                                                        <span class="ms-1 text-muted">(@lessonAccess.Rating/5)</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span>Not Yet Rated</span>
                                                }
                                            </td>
                                            <td>@lessonAccess.Feedback</td>
                                        </tr>

                                        index++;
                                    }


                                </tbody>
                            </table>

                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-12 col-sm-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Lesson References</h5>
                </div>
                <div class="card-body">

                    @if (Model.BatchLessonReferences != null && Model.BatchLessonReferences.Any(r => !r.IsDeleted))
                    {
                        <div class="accordion" id="lessonRefsAccordion">
                            @{
                                var refs = Model.BatchLessonReferences.Where(r => !r.IsDeleted).ToList();

                                @for (int i = 0; i < refs.Count; i++)
                                {
                                    var r = refs[i];
                                    var headingId = $"refHeading{i}";
                                    var collapseId = $"refCollapse{i}";
                                    var isFirst = i == 0;
                                    var viewerUrl = r.ReferenceUrl
                                    .Replace("/view?usp=sharing", "/preview")
                                    .Replace("/view", "/preview");

                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="@headingId">

                                            <button type="button"
                                                    class="btn-delete-ref"
                                                    title="Delete Reference"
                                                    onclick="deleteReference('@r.EncryptedKey')">
                                                <i class="fas fa-trash-can"></i>
                                            </button>

                                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#@collapseId"
                                                    aria-expanded="@(isFirst ? "true" : "false")"
                                                    aria-controls="@collapseId">
                                                @(string.IsNullOrWhiteSpace(r.Description) ? $"Reference {i + 1}" : r.Description)
                                            </button>
                                        </h2>

                                        <div id="@collapseId"
                                             class="accordion-collapse collapse @(isFirst ? "show" : "")"
                                             aria-labelledby="@headingId"
                                             data-bs-parent="#lessonRefsAccordion">
                                            <div class="accordion-body">
                                                <div class="ratio ratio-16x9">
                                                    <iframe src="@viewerUrl" allowfullscreen></iframe>
                                                </div>

                                                <div class="mt-2 d-flex gap-2">
                                                    <a class="btn btn-sm btn-outline-primary" href="@r.ReferenceUrl" target="_blank" rel="noopener">
                                                        Open in new tab
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No references added for this lesson.</div>
                    }

                </div>
            </div>
        </div>
    </div>

</div>

<!-- Custom Confirmation Modal -->
<div class="confirm-modal-overlay" id="deleteConfirmModal">
    <div class="confirm-modal-card">
        <div class="modal-icon-wrapper">
            <i class="fas fa-triangle-exclamation"></i>
        </div>
        <h4 class="modal-title">Delete Reference?</h4>
        <p class="modal-text">Are you sure you want to remove this lesson reference? This action cannot be undone.</p>
        <div class="modal-actions">
            <button type="button" class="btn-modal btn-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
            <button type="button" class="btn-modal btn-modal-delete" id="confirmDeleteBtn">Delete</button>
        </div>
    </div>
</div>

@section Scripts {

    <script>

        $(document).ready(function () {
            initializeRatingDataTable();
        });

        var tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        var firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);


        var player;

        function onYouTubeIframeAPIReady() {
            player = new YT.Player('player', {
                width: '100%',
                videoId: '@videoId',
                playerVars: {
                    controls: 1,
                    playsinline: 1,
                    rel: 0
                },
                events: {
                    onReady: onPlayerReady,
                    onStateChange: onPlayerStateChange
                }
            });
        }


        function onPlayerReady(event) {
          event.target.playVideo();
        }


        var done = false;
        function onPlayerStateChange(event) {
            if (event.data == YT.PlayerState.PLAYING && !done) {
                setTimeout(stopVideo, 6000);
                done = true;
            }
        }

        function stopVideo() {
            player.stopVideo();
        }


        function initializeRatingDataTable() {
            if ($.fn.DataTable.isDataTable('#ratingDataTable')) {
                $('#ratingDataTable').DataTable().destroy();
            }

            $('#ratingDataTable').DataTable({
                processing: false,
                serverSide: false,
                paging: true,
                pageLength: 10,
                lengthChange: false,
                searching: true,
                ordering: true,
                info: true,
                autoWidth: false,
                responsive: true,
                language: {
                    emptyTable: "No ratings available"
                },
                columnDefs: [
                    { orderable: false, targets: 0 }
                ]
            });
        }

        let referenceKeyToDelete = null;

        function deleteReference(encryptedKey) {
            referenceKeyToDelete = encryptedKey;
            const modal = document.getElementById('deleteConfirmModal');
            modal.style.display = 'flex';
            setTimeout(() => modal.classList.add('show'), 10);
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteConfirmModal');
            modal.classList.remove('show');
            setTimeout(() => {
                modal.style.display = 'none';
                referenceKeyToDelete = null;
            }, 300);
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
            if (!referenceKeyToDelete) return;

            const btn = this;
            const originalContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Deleting...';

            $.ajax({
                url: '/AdminPortal/BatchLesson/DeleteBatchLessonReference',
                type: 'POST',
                data: { q: referenceKeyToDelete },
                success: function (response) {
                    if (response.success) {
                        popUpNotification('success', response.message);
                        location.reload();
                    } else {
                        popUpNotification('error', response.message);
                        btn.disabled = false;
                        btn.innerHTML = originalContent;
                    }
                },
                error: function () {
                    popUpNotification('error', 'An error occurred while deleting the reference.');
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                }
            });
        });

    </script>

}