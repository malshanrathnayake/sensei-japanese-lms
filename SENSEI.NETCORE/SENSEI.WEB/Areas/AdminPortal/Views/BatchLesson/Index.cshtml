@using SENSEI.DOMAIN
@using core_web.Helpers
@model BatchLesson

@{
    ViewData["Title"] = "Batch Lessons";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Batch Lessons</h1>
            <p class="text-muted small mb-0">Manage and schedule lessons for specific batches.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewBatchLesson" data-action-url="/AdminPortal/BatchLesson/Create">
            <i class="fas fa-plus me-2"></i> New Lesson
        </button>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4 g-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid var(--sensei-red) !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-primary text-primary rounded-circle p-2 me-3">
                        <i data-feather="calendar" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Total Lessons</h6>
                        <h4 class="fw-900 mb-0" id="stat-total-lessons">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #00c292 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-success text-success rounded-circle p-2 me-3">
                        <i data-feather="video" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Recordings</h6>
                        <h4 class="fw-900 mb-0" id="stat-recordings">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #03a9f3 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-info text-info rounded-circle p-2 me-3">
                        <i data-feather="clock" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Upcoming</h6>
                        <h4 class="fw-900 mb-0" id="stat-upcoming">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #ab8ce4 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-warning text-warning rounded-circle p-2 me-3">
                        <i data-feather="users" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Batches</h6>
                        <h4 class="fw-900 mb-0" id="stat-batches">...</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
        <div class="card-body p-4">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-filter"></i>
                    </div>
                </div>
                <div class="col">
                    <h5 class="mb-0 fw-800">Filter View</h5>
                    <p class="text-muted small mb-0">Select a batch to narrow down the lesson schedule.</p>
                </div>
                <div class="col-md-4">
                    <select id="SearchBatchId" class="form-control select2 search-batch-select shadow-none border-light-subtle bg-white"></select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-light rounded-pill px-4 fw-bold" onclick="location.reload();">
                        <i class="fas fa-sync-alt me-2"></i> Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="card-title mb-0 fw-800">Assigned Lessons</h5>
        </div>
        <div class="card-body p-0">
            <div id="BatchLessonTableContent" class="table-responsive">
                <table id="BatchLessonDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 40px;"></th>
                            <th>Batch</th>
                            <th>Lesson Title</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th>Recording</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("BatchLessonOffCanvas", "BatchLesson", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/batch-lesson-function.js"></script>
    <script src="~/js/admin-portal/batch-lesson-reference-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchBatchId').change(function () {
                updateUrlParameter('page', 1);
                loadBatchLessons();
            });

            $.getJSON('/AdminPortal/BatchLesson/GetBatchListJsonResult', function (data) {
                $('#SearchBatchId').empty();
                $('#SearchBatchId').append('<option value="0">All Batches</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-batch-select',
                    title: 'Select Batch'
                });

                var batchId = $('#SearchBatchId').val();
                if (batchId) {
                    $('#SearchBatchId').val(batchId).trigger('change');
                }
            });

            loadBatchLessons();

        });

        function loadBatchLessons() {

            if ($.fn.DataTable.isDataTable('#BatchLessonDataTable')) {
                $('#BatchLessonDataTable').DataTable().clear().destroy();
                $('#BatchLessonDataTable tbody').empty();
            }

            const urlParams = new URLSearchParams(window.location.search);
            const pageParam = urlParams.get('page');
            const pageLength = 25;
            const startPage = pageParam ? (parseInt(pageParam) - 1) * pageLength : 0;

            var table = $('#BatchLessonDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: pageLength,
                displayStart: startPage,
                columnDefs: [
                    { targets: 0, className: 'noVis ps-3' },
                    { width: 40, targets: 0, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/BatchLesson/ListOfBatchLessons',
                    type: 'POST',
                    data: function (d) {
                        d.batchId = $('#SearchBatchId').val() || 0;
                    }
                },
                columns: [
                    {
                        data: null,
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            var editUrl = `/AdminPortal/BatchLesson/Edit/?q=${row.encryptedKey}`;
                            var deleteUrl = `/AdminPortal/BatchLesson/Delete/?q=${row.encryptedKey}`;
                            var addReferenceUrl = `/AdminPortal/BatchLesson/AddReference/?q=${row.encryptedKey}`;
                            var viewUrl = `/AdminPortal/BatchLesson/View/?q=${row.encryptedKey}`;

                            return `
                                <div class="d-flex justify-content-center gap-1">
                                    <a href="${viewUrl}" class="btn btn-sm btn-soft-info p-1 px-2 rounded-pill" title="View Overview">
                                        <i data-feather="eye" style="width: 14px; height: 14px;"></i>
                                    </a>
                                    <button class="btn btn-sm btn-soft-primary p-1 px-2 rounded-pill edit-batch-lesson" data-action-url="${editUrl}" title="Edit Details">
                                        <i data-feather="edit" style="width: 14px; height: 14px;"></i>
                                    </button>
                                    <button class="btn btn-sm btn-soft-warning p-1 px-2 rounded-pill add-batch-lesson-reference" data-action-url="${addReferenceUrl}" title="Manage References">
                                        <i data-feather="link" style="width: 14px; height: 14px;"></i>
                                    </button>
                                    <button class="btn btn-sm btn-soft-danger p-1 px-2 rounded-pill delete-batch-lesson" data-action-url="${deleteUrl}" data-action-parameter="${row.batch ? row.batch.batchName : ''}" title="Delete">
                                        <i data-feather="trash-2" style="width: 14px; height: 14px;"></i>
                                    </button>
                                </div>`;
                        }
                    },
                    { data: 'batch.batchName', name: 'batch.batchName', defaultContent: '', render: function(d) { return `<span class="fw-bold text-dark">${d||'—'}</span>`; } },
                    { data: 'lesson.lessonName', name: 'lesson.lessonName', defaultContent: '', render: function(d) { return `<div class="fw-bold text-dark" style="font-size: 0.95rem;">${d||'No Title'}</div>`; } },
                    { data: 'description', name: 'description', defaultContent: 'N/A', render: function(d) { return `<div class="text-secondary" style="font-size: 0.9rem; max-width: 300px; white-space: normal; line-height: 1.4;">${d||'—'}</div>`; } },
                    { data: 'lessonDateTime', name: 'lessonDateTime', render: function (data) { return `<div class="text-dark fw-500" style="font-size: 0.9rem;">${renderDateOnly(data)}</div>`; } },
                    { 
                        data: 'recordingUrl', 
                        name: 'recordingUrl', 
                        defaultContent: '', 
                        render: function (data) { 
                            if (data) {
                                return `<a href="${data}" target="_blank" class="btn btn-sm btn-soft-success rounded-pill px-3 fw-bold" style="font-size: 0.75rem;"><i class="fas fa-play-circle me-1"></i> Watch</a>`;
                            } else {
                                return `<span class="badge bg-soft-warning text-warning rounded-pill px-3" style="font-size: 0.7rem; font-weight: 700;"><i class="fas fa-video-slash me-1"></i> Missing</span>`;
                            }
                        } 
                    },
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }
                    
                    // Calculate and display stats from the table data
                    var tableData = $('#BatchLessonDataTable').DataTable().rows().data();
                    var total = tableData.length;
                    var withRecordings = 0;
                    var upcoming = 0;
                    var now = new Date();
                    var batches = new Set();

                    tableData.each(function(row) {
                        if (row.recordingUrl) withRecordings++;
                        if (new Date(row.lessonDateTime) > now) upcoming++;
                        if (row.batch) batches.add(row.batch.batchId);
                    });

                    $('#stat-total-lessons').text(total);
                    $('#stat-recordings').text(withRecordings);
                    $('#stat-upcoming').text(upcoming);
                    $('#stat-batches').text(batches.size || 0);

                    editBatchLessonButton();
                    deleteBatchLessonButton();
                    addBatchLessonReferenceButton();
                }
            });

            table.on('page.dt', function () {
                var info = table.page.info();
                updateUrlParameter('page', info.page + 1);
            });
        }

        function updateUrlParameter(key, value) {
            var url = new URL(window.location.href);
            url.searchParams.set(key, value);
            window.history.replaceState({ path: url.href }, '', url.href);
        }

        function renderDateOnly(data) {
            if (!data) return '—';
            return data.split('T')[0];
        }

    </script>

}
