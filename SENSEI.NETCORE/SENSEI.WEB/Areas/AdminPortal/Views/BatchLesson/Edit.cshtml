@using SENSEI.DOMAIN
@model BatchLesson

@{
    Layout = null;
}

<div class="offcanvas-header py-3 px-4">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-soft-primary text-primary p-2 rounded-3">
            <i data-feather="edit" style="width: 24px; height: 24px;"></i>
        </div>
        <h5 class="offcanvas-title mb-0">Edit Batch Lesson</h5>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>

<div class="offcanvas-body p-4">

    <form id="batch-lesson-edit-form" asp-area="AdminPortal" asp-controller="BatchLesson" asp-action="Edit"
          data-ajax="true" data-ajax-method="POST"
          data-ajax-begin="onBatchLessonEditBegin" data-ajax-success="onBatchLessonEditSuccess" data-ajax-failure="onBatchLessonEditFailure" data-ajax-complete="onBatchLessonEditComplete">

        <input type="hidden" id="BatchLessonId" name="BatchLessonId" value="@Model.BatchLessonId" />
        <input type="hidden" id="hdnBatchId" name="hdnBatchId" value="@Model.BatchId" />
        <input type="hidden" id="hdnLessonId" name="hdnLessonId" value="@Model.LessonId" />

        <div class="mb-4" id="edit-batch-wrapper">
            <label class="form-label">Batch Selection</label>
            <select id="EditBatchId" class="form-control edit-batch-select" asp-for="BatchId" name="BatchId"></select>
            <span asp-validation-for="BatchId" class="text-danger small fw-bold"></span>
        </div>

        <div class="mb-4" id="edit-lesson-wrapper">
            <label class="form-label">Lesson Content</label>
            <select id="EditLessonId" class="form-control edit-lesson-select" asp-for="LessonId" name="LessonId"></select>
            <span asp-validation-for="LessonId" class="text-danger small fw-bold"></span>
        </div>

        <div class="mb-4">
            <label class="form-label">Short Description</label>
            <textarea class="form-control" asp-for="Description" rows="2" placeholder="Enter lesson details..."></textarea>
            <span asp-validation-for="Description" class="text-danger small fw-bold"></span>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div class="mb-4">
                    <label class="form-label">Lesson Schedule Date</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i data-feather="calendar" style="width: 16px; height: 16px;"></i></span>
                        <input type="text" id="LessonDateTime" class="form-control datepicker" asp-for="LessonDateTime" placeholder="Select Date" autocomplete="off" value="@(Model.LessonDateTime.ToString("yyyy-MM-dd"))" />
                    </div>
                    <span asp-validation-for="LessonDateTime" class="text-danger small fw-bold"></span>
                </div>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Recording Link (URL)</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-0"><i data-feather="link" style="width: 16px; height: 16px;"></i></span>
                <input class="form-control" asp-for="RecordingUrl" placeholder="https://..." />
            </div>
            <span asp-validation-for="RecordingUrl" class="text-danger small fw-bold"></span>
        </div>

        <div class="mb-4">
            <label class="form-label">Recording Expiry Date</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-0"><i data-feather="clock" style="width: 16px; height: 16px;"></i></span>
                <input type="text" id="RecordingExpireDate" class="form-control datepicker" asp-for="RecordingExpireDate" placeholder="Select Expiry" autocomplete="off" value="@(Model.RecordingExpireDate.ToString("yyyy-MM-dd"))" />
            </div>
            <span asp-validation-for="RecordingExpireDate" class="text-danger small fw-bold"></span>
        </div>

        <div class="mt-5 d-flex gap-2">
            <button type="button" class="btn btn-light rounded-pill px-4 flex-grow-1 fw-bold" data-bs-dismiss="offcanvas">
                Cancel
            </button>
            <button type="submit" id="btnUpdateBatchLesson" class="btn btn-primary rounded-pill px-4 flex-grow-1 fw-bold ladda-button" data-style="zoom-in">
                <span class="ladda-label">Save Changes</span>
            </button>
        </div>

    </form>

</div>
