@using core_web.Helpers
@{
    ViewData["Title"] = "Course Management";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Courses</h1>
            <p class="text-muted small mb-0">Manage educational programs and core curriculum.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewCourse" data-action-url="/AdminPortal/Course/Create">
            <i class="fas fa-plus me-2"></i> New Course
        </button>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4 g-3">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid var(--sensei-red) !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-primary text-primary rounded-circle p-2 me-3">
                        <i data-feather="book" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Total Courses</h6>
                        <h4 class="fw-900 mb-0" id="stat-total-courses">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #00c292 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-success text-success rounded-circle p-2 me-3">
                        <i data-feather="check-circle" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Active Programs</h6>
                        <h4 class="fw-900 mb-0" id="stat-active">...</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="card-title mb-0 fw-800">Available Courses</h5>
        </div>
        <div class="card-body p-0">
            <div id="CourseTableContent" class="table-responsive">
                <table id="CourseDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th style="display:none;">ID</th>
                            <th class="ps-4" style="width: 80px;"></th>
                            <th>Course Name</th>
                            <th>Course Code</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("CourseOffCanvas", "Course", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/course-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {
            loadCourses();
        });

        function loadCourses() {

            if ($.fn.DataTable.isDataTable('#CourseDataTable')) {
                $('#CourseDataTable').DataTable().clear().destroy();
                $('#CourseDataTable tbody').empty();
            }

            const urlParams = new URLSearchParams(window.location.search);
            const pageParam = urlParams.get('page');
            const pageLength = 25;
            const startPage = pageParam ? (parseInt(pageParam) - 1) * pageLength : 0;

            var table = $('#CourseDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: pageLength,
                displayStart: startPage,
                order: [[0, "desc"]], // New Courses First
                columnDefs: [
                    { targets: 0, visible: false }, // Hide ID
                    { targets: 1, className: 'noVis ps-3' },
                    { width: 80, targets: 1, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/Course/ListOfCourses',
                    type: 'POST'
                },
                columns: [
                    { data: 'courseId', name: 'courseId' },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            var editUrl = `/AdminPortal/Course/Edit/?q=${row.encryptedKey}`;
                            var deleteUrl = `/AdminPortal/Course/Delete/?q=${row.encryptedKey}`;

                            return `
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-soft-primary p-1 px-2 rounded-pill edit-course" data-action-url="${editUrl}" title="Edit Course">
                                        <i data-feather="edit" style="width: 14px; height: 14px;"></i>
                                    </button>
                                    <button class="btn btn-sm btn-soft-danger p-1 px-2 rounded-pill delete-course" data-action-url="${deleteUrl}" data-action-parameter="${row.courseName}" title="Delete Course">
                                        <i data-feather="trash-2" style="width: 14px; height: 14px;"></i>
                                    </button>
                                </div>`;
                        }
                    },
                    { data: 'courseName', name:'courseName', render: function(d) { return `<div class="fw-800 text-primary" style="font-size: 0.95rem;">${d}</div>`; } },
                    { data: 'courseCode', name:'courseCode', render: function(d) { return `<code class="bg-soft-primary px-3 py-1 rounded-pill small text-primary fw-bold" style="font-size: 0.75rem;">${d}</code>`; } },
                    { data: null, render: function() { return `<span class="badge bg-soft-success text-success rounded-pill px-3 fw-bold" style="font-size: 0.65rem;">ACTIVE</span>`; } }
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }

                    // Calculate stats
                    var total = $('#CourseDataTable').DataTable().rows().data().length;
                    $('#stat-total-courses').text(total);
                    $('#stat-active').text(total);

                    editCourseButton();
                    deleteCourseButton();
                }
            });

            table.on('page.dt', function () {
                var info = table.page.info();
                updateUrlParameter('page', info.page + 1);
            });
        }

        function updateUrlParameter(key, value) {
            var url = new URL(window.location.href);
            url.searchParams.set(key, value);
            window.history.replaceState({ path: url.href }, '', url.href);
        }

    </script>

}
