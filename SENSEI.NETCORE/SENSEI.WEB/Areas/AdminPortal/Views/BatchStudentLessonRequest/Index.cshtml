@using SENSEI.DOMAIN
@using core_web.Helpers
@model BatchStudentLessonAccessRequest

@{
    ViewData["Title"] = "Lesson Access Management";
}

<style>
    .avatar-circle {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--sensei-red) 0%, var(--sensei-red-dark) 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: 800;
        font-size: 0.85rem;
        box-shadow: 0 4px 10px rgba(216, 50, 54, 0.2);
    }
    .stats-card-premium {
        border: none !important;
        border-radius: 20px !important;
        background: white;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02) !important;
    }
    .stats-card-premium:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
    }
    .stats-icon-box {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    #LessonRequestDataTable thead th {
        background-color: #f8f9fa;
        color: #495057;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        padding: 1rem;
        border-bottom: 2px solid #f1f3f5;
    }
    .badge-premium {
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
</style>

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Student Lesson Requests</h1>
            <p class="text-muted small mb-0">Review and authorize student access to specific course material.</p>
        </div>
    </div>

    <!-- Statistics Row -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card stats-card-premium">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-warning text-warning me-3">
                            <i class="fas fa-hourglass-start"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Pending Approval</h6>
                            <h3 class="mb-0 fw-900" id="stat-pending">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stats-card-premium">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-success text-success me-3">
                            <i class="fas fa-lock-open"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Access Granted</h6>
                            <h3 class="mb-0 fw-900" id="stat-approved">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stats-card-premium">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-primary text-primary me-3">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Total Requests</h6>
                            <h3 class="mb-0 fw-900" id="stat-total">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0 fw-800"><i class="fas fa-filter me-2 text-primary"></i> Filter Requests</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label smaller text-muted fw-bold">BY COURSE</label>
                    <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-light"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label smaller text-muted fw-bold">BY BATCH</label>
                    <select id="SearchBatchId" class="form-control select2 search-batch-select shadow-none border-light-subtle bg-light"></select>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-800">Lesson Access History</h5>
            <button class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="loadBatchStudentLessonRequests()">
                <i class="fas fa-sync-alt me-1"></i> Refresh
            </button>
        </div>
        <div class="card-body p-0">
            <div id="LessonRequestTableContent" class="table-responsive">
                <table id="LessonRequestDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 40px;"></th>
                            <th>Batch & Lesson</th>
                            <th>Student</th>
                            <th>Reference</th>
                            <th>Requested On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("BatchStudentLessonOffCanvas", "BatchStudentLessonRequest", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/BatchStudentLessonRequest-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                loadBatchStudentLessonRequests();
                loadBatches();
            });

            $('#SearchBatchId').change(function () {
                loadBatchStudentLessonRequests();
            });

            $.getJSON('/AdminPortal/BatchStudentLessonRequest/GetCourseListJsonResult', function (data) {
                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();
                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
                loadBatches();
            });

            function loadBatches(){
                $.getJSON('/AdminPortal/BatchStudentLessonRequest/GetBatchListJsonResult',
                    { courseId: $('#SearchCourseId').val() || 0 },
                    function (data) {
                        $('#SearchBatchId').empty();
                        $('#SearchBatchId').append('<option value="0">All Batches</option>')

                        loadSelectBox({
                            data: data,
                            className: 'search-batch-select',
                            title: 'Select Batch'
                        });

                        var batchId = $('#SearchBatchId').val();
                        if (batchId) {
                            $('#SearchBatchId').val(batchId).trigger('change');
                        }
                    });
            }

            loadBatchStudentLessonRequests();

        });

        function loadBatchStudentLessonRequests() {

            if ($.fn.DataTable.isDataTable('#LessonRequestDataTable')) {
                $('#LessonRequestDataTable').DataTable().clear().destroy();
                $('#LessonRequestDataTable tbody').empty();
            }

            $('#LessonRequestDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                columnDefs: [
                    { targets: 0, className: 'noVis ps-3' },
                    { width: 40, targets: 0, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/BatchStudentLessonRequest/ListOfBatchStudentLessonRequests',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                        d.batchId = $('#SearchBatchId').val() || 0;
                    }
                },
                columns: [
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {

                            var approveUrl = `/AdminPortal/BatchStudentLessonRequest/Approve/?q=${row.encryptedKey}`;
                            var approveBtn = '';

                             if(row.approveStatusEnum != 1 && row.approveStatusEnum != 2){
                                 approveBtn = `<li><a class="dropdown-item d-flex align-items-center gap-2 text-success approve-request" href="javascript:void(0)" data-action-url="${approveUrl}"> <i data-feather="check-circle" style="width: 14px; height: 14px;"></i><span>Grant Lesson Access</span></a></li>`;
                             } else {
                                 approveBtn = `<li><a class="dropdown-item d-flex align-items-center gap-2 disabled opacity-50" href="javascript:void(0)"> <i data-feather="check-circle" style="width: 14px; height: 14px;"></i><span>Request Finalized</span></a></li>`;
                             }

                             return `
                                 <div class="dropdown">
                                     <button class="btn btn-sm btn-light border-0 p-1 rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 32px; height: 32px;">
                                         <i data-feather="more-vertical" style="width: 16px; height: 16px;"></i>
                                     </button>
                                     <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 0.75rem; min-width: 180px;">
                                         <li><h6 class="dropdown-header smaller text-muted fw-bold">ACCESS ACTIONS</h6></li>
                                         ${approveBtn}
                                         <div class="dropdown-divider"></div>
                                         <li><a class="dropdown-item d-flex align-items-center gap-2 text-danger" href="javascript:void(0)"><i data-feather="slash" style="width: 14px; height: 14px;"></i>Void Request</a></li>
                                     </ul>
                                 </div>`;
                        }
                    },
                    { 
                        data: 'batchStudentLessonAccess.batchLesson.batch.batchName', 
                        name:'batchName',
                        render: function(d, t, r) {
                            return `<div class="fw-bold text-dark">${d||'No Batch'}</div><div class="text-muted smaller">${r.batchStudentLessonAccess.batchLesson.lesson.lessonName}</div>`;
                        }
                    },
                     { 
                         data: 'batchStudentLessonAccess.student.studentPopulatedName', 
                         name:'studentPopulatedName',
                         render: function(d, t, r) {
                             var initial = d.substring(0, 1).toUpperCase();
                             return `
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle">${initial}</div>
                                    <div>
                                        <div class="fw-bold text-dark">${d}</div>
                                        <div class="text-muted smaller">Index: ${r.batchStudentLessonAccess.student.indexNumber}</div>
                                    </div>
                                </div>`;
                         }
                     },
                    { data: 'batchStudentLessonAccess.batchLesson.description', name:'description', render: function(d) { return `<small class="text-muted">${d||'—'}</small>`; } },
                    { data: 'requestedDate', name:'requestedDate', render: function (data) { return renderDateTime(data); } },
                    { 
                        data: null, 
                        name: 'status', 
                        orderable: false, 
                        render: function (data, type, row) {
                            if (row.approveStatusEnum === 0) {
                                return `<span class="badge bg-soft-warning text-warning border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">PENDING</span>`;
                            }
                            if (row.approveStatusEnum === 1) {
                                return `<span class="badge bg-soft-success text-success border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">APPROVED</span>`;
                            }
                            if (row.approveStatusEnum === 2) {
                                return `<span class="badge bg-soft-danger text-danger border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">REJECTED</span>`;
                            }
                            return '';
                        }
                    }
                ],
                 drawCallback: function (settings) {
                    if (window.feather) { feather.replace(); }
                    approveButton();

                    // Update local stats from table metadata
                    if (settings.json) {
                        $('#stat-total').text(settings.json.recordsTotal);
                        // For granular stats, we usually need a separate API like we did for Registration.
                        // I will keep them updated if the API is available or just show total for now.
                    }
                }
            });
        }

        function renderDateTime(data) {
            if (!data) return '—';
            var date = data.split('T')[0];
            var time = data.split('T')[1].split('.')[0];
            return `<div>${date}</div><div class="smaller text-muted" style="font-size: 0.7rem;">${time}</div>`;
        }

    </script>

}
