@using SENSEI.DOMAIN
@model BatchStudentLessonAccessRequest

@{
    Layout = null;
}



<div class="offcanvas-header">
    <h5 class="offcanvas-title">Approve</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>

<div class="offcanvas-body">

    <form id="BatchStudentLessonRequest-Approve-create-form" asp-area="AdminPortal" asp-controller="BatchStudentLessonRequest" asp-action="Approve"
          data-ajax="true" data-ajax-method="POST"
          data-ajax-begin="onApproveCreateBegin" data-ajax-success="onApproveCreateSuccess" data-ajax-failure="onApproveCreateFailure" data-ajax-complete="onApproveCreateComplete">


        @Html.HiddenFor(m => m.BatchStudentLessonAccessRequestId)

        <div class="mb-3">
            <label class="form-label">@Html.DisplayNameFor(m => m.BatchStudentLessonAccess.Student.IndexNumber)</label>
            <input id="CourseId" class="form-control course-select" value="@Model.BatchStudentLessonAccess.Student.IndexNumber" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">@Html.DisplayNameFor(m => m.BatchStudentLessonAccess.Student.StudentPopulatedName)</label>
            <input id="CourseId" class="form-control course-select" value="@Model.BatchStudentLessonAccess.Student.StudentPopulatedName" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">@Html.DisplayNameFor(m => m.BatchStudentLessonAccess.BatchLesson.Lesson.LessonName)</label>
            <input class="form-control" value="@Model.BatchStudentLessonAccess.BatchLesson.Lesson.LessonName" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">@Html.DisplayNameFor(m => m.BatchStudentLessonAccess.BatchLesson.Description)</label>
            <input class="form-control" value="@Model.BatchStudentLessonAccess.BatchLesson.Description" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">@Html.DisplayNameFor(m => m.RequestedDate)</label>
            <input class="form-control" value="@Model.RequestedDate.ToString("MMM-yyyy")" readonly />
        </div>

        <div class="d-flex justify-content-end gap-2">

            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">
                Cancel
            </button>

            <button type="submit" id="btnApprove" class="btn btn-success ladda-button" data-style="zoom-in">
                <span class="ladda-label">Approve</span>
            </button>

        </div>

    </form>

</div>
