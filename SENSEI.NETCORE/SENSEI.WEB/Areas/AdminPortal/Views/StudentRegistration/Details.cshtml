@using SENSEI.DOMAIN
@model StudentRegistration

@{
    Layout = null;
}

<div class="offcanvas-header bg-light border-bottom py-3">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
            <i data-feather="user" style="width: 24px; height: 24px;"></i>
        </div>
        <div>
            <h5 class="offcanvas-title fw-bold mb-0">Registration Details</h5>
            <p class="text-muted small mb-0">ID: #@Model.StudentRegistrationId</p>
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>

<div class="offcanvas-body p-4">
    <div class="mb-4 text-center">
        <div class="avatar avatar-xl mb-3 mx-auto">
            <div class="rounded-circle bg-soft-primary text-primary d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                @Model.StudentRegistrationPopulatedName.Substring(0, 1).ToUpper()
            </div>
        </div>
        <h4 class="fw-bold mb-1">@Model.StudentRegistrationPopulatedName</h4>
        <div class="d-flex justify-content-center gap-2">
            @if (Model.IsApproved)
            {
                <span class="badge bg-soft-success text-success px-3 py-2 rounded-pill">APPROVED</span>
            }
            else if (Model.IsRejected)
            {
                <span class="badge bg-soft-danger text-danger px-3 py-2 rounded-pill">REJECTED</span>
            }
            else
            {
                <span class="badge bg-soft-warning text-warning px-3 py-2 rounded-pill">PENDING</span>
            }
        </div>
    </div>

    <div class="row g-4 overflow-hidden">
        <div class="col-12">
            <h6 class="text-uppercase text-muted fw-bold smaller mb-3" style="letter-spacing: 0.1em;">Course Information</h6>
            <div class="card border-0 bg-light p-3 rounded-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Course</span>
                    <span class="fw-bold small text-dark">@Model.Course.CourseName</span>
                </div>
                @if (Model.Batch != null)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Selected Batch</span>
                        <span class="fw-bold small text-primary">@Model.Batch.BatchName</span>
                    </div>
                }
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Learning Mode</span>
                    <span class="badge bg-white text-dark border px-2 py-1 small">@Model.StudentLearningMode.LearningModeName</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Registration Date</span>
                    <span class="text-dark small">@Model.CreatedDateTime.ToString("MMMM dd, yyyy")</span>
                </div>
            </div>
        </div>

        <div class="col-12">
            <h6 class="text-uppercase text-muted fw-bold smaller mb-3" style="letter-spacing: 0.1em;">Personal Details</h6>
            <div class="card border-0 bg-light p-3 rounded-4">
                <div class="row g-3">
                    <div class="col-6">
                        <p class="text-muted small mb-0">NIC Number</p>
                        <p class="fw-600 mb-0">@Model.NIC</p>
                    </div>
                    <div class="col-6">
                        <p class="text-muted small mb-0">Date of Birth</p>
                        <p class="fw-600 mb-0">@Model.DateOfBirth.ToString("yyyy-MM-dd")</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.IndexNumber))
                    {
                        <div class="col-12 mt-2">
                            <p class="text-muted small mb-0">Provided Index Number</p>
                            <p class="fw-bold mb-0 text-primary">@Model.IndexNumber</p>
                        </div>
                    }
                    <div class="col-12 mt-2">
                        <p class="text-muted small mb-1">Residential Address</p>
                        <div class="bg-white p-2 px-3 rounded-3 border-0 shadow-sm">
                            <p class="mb-0 small text-dark">
                                @Model.AddressLineOne<br />
                                @Model.City@(!string.IsNullOrEmpty(Model.State) ? $", {Model.State}" : "")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <h6 class="text-uppercase text-muted fw-bold smaller mb-3" style="letter-spacing: 0.1em;">Contact Details</h6>
            <div class="card border-0 bg-light p-3 rounded-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="bg-white p-2 rounded-3 text-primary shadow-sm">
                        <i data-feather="mail" style="width: 16px; height: 16px;"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Email Address</p>
                        <p class="fw-600 mb-0">@Model.Email</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white p-2 rounded-3 text-success shadow-sm">
                        <i data-feather="phone" style="width: 16px; height: 16px;"></i>
                    </div>
                    <div>
                        <p class="text-muted small mb-0">Phone Number</p>
                        <p class="fw-600 mb-0">@Model.PhoneNo</p>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.IsRejected && !string.IsNullOrEmpty(Model.RejectionComment))
        {
            <div class="col-12">
                <h6 class="text-uppercase text-muted fw-bold smaller mb-3" style="letter-spacing: 0.1em;">Rejection Reason</h6>
                <div class="alert alert-soft-danger border-0 rounded-4">
                    <p class="mb-0 small">@Model.RejectionComment</p>
                </div>
            </div>
        }
    </div>

    <div class="mt-5 pt-3 border-top d-grid gap-2">
        <button type="button" class="btn btn-light fw-600 py-2 rounded-pill" data-bs-dismiss="offcanvas">Close</button>
    </div>
</div>

<script>
    if (window.feather) { feather.replace(); }
</script>
