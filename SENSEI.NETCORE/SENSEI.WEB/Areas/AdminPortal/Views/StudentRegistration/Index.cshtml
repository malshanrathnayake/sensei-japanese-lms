@using SENSEI.DOMAIN
@using core_web.Helpers
@model StudentRegistration

@{
    ViewData["Title"] = "Registration Management";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Student Registrations</h1>
            <p class="text-muted small mb-0">Review and approve incoming student admission requests.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewStudentRegister" data-action-url="/AdminPortal/StudentRegistration/Create">
            <i class="fas fa-plus me-2"></i> New Registration
        </button>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0 fw-800"><i class="fas fa-filter me-2 text-primary"></i> Filter by Course</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-light"></select>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-800">Registration Requests</h5>
        </div>
        <div class="card-body p-0">
            <div id="StudentRegistrationTableContent" class="table-responsive">
                <table id="StudentRegistrationDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 40px;"></th>
                            <th>Student</th>
                            <th>Applied Course</th>
                            <th>Mode</th>
                            <th>Contact Info</th>
                            <th>Submission Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("StudentRegistrationOffCanvas", "StudentRegistration", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/studentregistration-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                loadStudentRegistrations();
            });

            $.getJSON('/AdminPortal/StudentRegistration/GetCourseListJsonResult', function (data) {
                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();
                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            $('#btnNewStudentRegister').on('click', function () {
                var url = $(this).data('action-url');
                window.location.href = url;
            });

            loadStudentRegistrations();

        });

        function loadStudentRegistrations() {

            if ($.fn.DataTable.isDataTable('#StudentRegistrationDataTable')) {
                $('#StudentRegistrationDataTable').DataTable().clear().destroy();
                $('#StudentRegistrationDataTable tbody').empty();
            }

            $('#StudentRegistrationDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                columnDefs: [
                    { targets: 0, className: 'noVis ps-3' },
                    { width: 40, targets: 0, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/StudentRegistration/ListOfStudentRegistrations',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                    }
                },
                columns: [
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {

                            var approveUrl = `/AdminPortal/StudentRegistration/Approve/?q=${row.encryptedKey}`;
                            var rejectUrl = `/AdminPortal/StudentRegistration/Reject/?q=${row.encryptedKey}`;
                            var isFinalized = row.isApproved || row.isRejected;

                            var approveAction = `<li><a class="dropdown-item d-flex align-items-center gap-2 text-success ${isFinalized ? 'disabled opacity-50' : 'approve-registration'}" href="javascript:void(0)" data-action-url="${approveUrl}"> <i data-feather="check-circle" style="width: 14px; height: 14px;"></i><span>Approve Admission</span></a></li>`;
                            var rejectAction = `<li><a class="dropdown-item d-flex align-items-center gap-2 text-danger ${isFinalized ? 'disabled opacity-50' : 'reject-registration'}" href="javascript:void(0)" data-action-url="${rejectUrl}" data-action-parameter="${row.studentRegistrationPopulatedName}"><i data-feather="x-circle" style="width: 14px; height: 14px;"></i><span>Reject admission</span></a></li>`;

                            return `
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-light border-0 p-1 rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 32px; height: 32px;">
                                        <i data-feather="more-vertical" style="width: 16px; height: 16px;"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 0.75rem; min-width: 180px;">
                                        <li><h6 class="dropdown-header smaller text-muted fw-bold">ADMISSION ACTIONS</h6></li>
                                        ${approveAction}
                                        ${rejectAction}
                                        <div class="dropdown-divider"></div>
                                        <li><a class="dropdown-item d-flex align-items-center gap-2" href="javascript:void(0)"><i data-feather="eye" style="width: 14px; height: 14px;"></i>View Details</a></li>
                                    </ul>
                                </div>`;
                        }
                    },
                    { 
                        data: 'studentRegistrationPopulatedName', 
                        name:'studentRegistrationPopulatedName',
                        render: function(data, type, row) {
                            return `<div class="fw-bold text-dark">${data}</div><div class="text-muted smaller">${row.email}</div>`;
                        }
                    },
                    { data: 'course.courseName', name:'course.courseName' },
                    { data: 'studentLearningMode.learningModeName', name:'studentLearningMode.learningModeName' },
                    { 
                        data: 'phoneNo', 
                        name: 'phoneNo',
                        render: function(data, type, row) {
                            return `<div class="text-dark fw-600 small"><i class="fas fa-phone me-1 text-muted smaller"></i> ${data}</div>`;
                        }
                    },
                    { data: 'createdDateTime', name:'createdDateTime', render: function (data) { return `<div class="text-muted small">${renderDateOnly(data)}</div>`; } },
                    { 
                        data: null, 
                        name: 'status', 
                        orderable: false, 
                        render: function (data, type, row) {
                            if (row.isApproved) {
                                return `<span class="badge bg-soft-success text-success border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">APPROVED</span>`;
                            }
                            if (row.isRejected) {
                                return `<span class="badge bg-soft-danger text-danger border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">REJECTED</span>`;
                            }
                            return `<span class="badge bg-soft-warning text-warning border-0 px-3 py-2 rounded-pill fw-bold" style="font-size: 0.65rem; letter-spacing: 0.05em;">PENDING</span>`;
                        }
                    }
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }
                    approveButton();
                    rejectButton();
                }
            });
        }

        function renderDateOnly(data) {
            if (!data) return '';
            return data.split('T')[0];
        }

    </script>

}
