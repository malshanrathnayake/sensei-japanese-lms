@using SENSEI.DOMAIN
@using core_web.Helpers
@model SENSEI.DOMAIN.StudentRegistration

@{
    ViewData["Title"] = "Registration Management";
}

<style>
    .avatar-circle {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--sensei-red) 0%, var(--sensei-red-dark) 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-weight: 800;
        font-size: 0.85rem;
        box-shadow: 0 4px 10px rgba(216, 50, 54, 0.2);
    }
    .stats-card-premium {
        border: none !important;
        border-radius: 20px !important;
        background: white;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02) !important;
        cursor: pointer;
    }
    .stats-card-premium:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.05) !important;
    }
    .stats-card-premium.active-filter {
        background: #fffafa !important;
        border: 1px solid rgba(216, 50, 54, 0.3) !important;
        box-shadow: 0 10px 25px rgba(216, 50, 54, 0.1) !important;
        transform: translateY(-5px);
    }
    .stats-card-premium.active-filter h3 {
        color: var(--primary) !important;
    }
    .stats-icon-box {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    #StudentRegistrationDataTable thead th {
        background-color: #f8f9fa;
        color: #495057;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        padding: 1rem;
        border-bottom: 2px solid #f1f3f5;
    }
    .badge-premium {
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.65rem;
        letter-spacing: 0.05em;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    /* Mobile Enhancements */
    @@media (max-width: 768px) {
        .stats-card-premium { margin-bottom: 1rem; }
        .stats-icon-box { width: 40px; height: 40px; font-size: 1rem; }
        .stats-card-premium h3 { font-size: 1.25rem; }
        .stats-card-premium h6 { font-size: 0.6rem; }
        .stats-card-premium .card-body { padding: 1.25rem !important; }
        
        .hide-mobile { display: none !important; }
        .table-responsive { border: none !important; }
        
        .btn-new-mobile { width: 100%; margin-top: 1rem; }
        .page-header-mobile { flex-direction: column; align-items: flex-start !important; }
    }

    @@media (max-width: 576px) {
        .row-cols-mobile-2 > * {
            flex: 0 0 50%;
            max-width: 50%;
        }
    }
</style>

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4 page-header-mobile">
        <div>
            <h1 class="h3 mb-1 fw-bold">Student Registrations</h1>
            <p class="text-muted small mb-0">Review and approve incoming student admission requests.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm btn-new-mobile" id="btnNewStudentRegister" data-action-url="/AdminPortal/StudentRegistration/Create">
            <i class="fas fa-plus me-2"></i> New Registration
        </button>
    </div>

    <!-- Statistics Row -->
    <div class="row mb-2 row-cols-mobile-2">
        <div class="col-md-3 mb-3">
            <div class="card stats-card-premium h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-warning text-warning me-3">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Pending</h6>
                            <h3 class="mb-0 fw-900" id="stat-pending">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stats-card-premium h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-success text-success me-3">
                            <i class="fas fa-check-double"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Approved</h6>
                            <h3 class="mb-0 fw-900" id="stat-approved">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stats-card-premium h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-danger text-danger me-3">
                            <i class="fas fa-times-circle"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Rejected</h6>
                            <h3 class="mb-0 fw-900" id="stat-rejected">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card stats-card-premium h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="stats-icon-box bg-soft-primary text-primary me-3">
                            <i class="fas fa-users"></i>
                        </div>
                        <div>
                            <h6 class="text-muted small fw-bold text-uppercase mb-1">Total</h6>
                            <h3 class="mb-0 fw-900" id="stat-total">--</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1.25rem;">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="card-title mb-0 fw-900 fs-6"><i class="fas fa-sliders-h me-2 text-primary"></i> Control Panel</h5>
        </div>
        <div class="card-body pt-0">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-2">Filter by Course</label>
                    <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-light"></select>
                </div>
                <div class="col-md-2 ms-auto">
                    <button type="button" class="btn btn-outline-primary w-100 rounded-pill fw-bold small" onclick="loadStudentRegistrations()">
                        <i class="fas fa-sync-alt me-2"></i> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-800">Registration Requests</h5>
        </div>
        <div class="card-body p-0">
            <div id="StudentRegistrationTableContent" class="table-responsive">
                <table id="StudentRegistrationDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 40px;"></th>
                            <th>Student</th>
                            <th class="hide-mobile">Applied Course</th>
                            <th class="hide-mobile">Mode</th>
                            <th class="hide-mobile">Contact Info</th>
                            <th class="hide-mobile">Submission Date</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("StudentRegistrationOffCanvas", "StudentRegistration", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/studentregistration-function.js"></script>

    <script type="text/javascript">
        var selectedStatus = 0; // 0: All, 1: Pending, 2: Approved, 3: Rejected

        $(document).ready(function () {
            // Read status from URL if present
            const urlParams = new URLSearchParams(window.location.search);
            const statusParam = urlParams.get('status');
            if (statusParam) {
                selectedStatus = parseInt(statusParam);
                // Update the active state of cards
                $('.stats-card-premium').removeClass('active-filter');
                if (selectedStatus === 1) $('#stat-pending').closest('.stats-card-premium').addClass('active-filter');
                else if (selectedStatus === 2) $('#stat-approved').closest('.stats-card-premium').addClass('active-filter');
                else if (selectedStatus === 3) $('#stat-rejected').closest('.stats-card-premium').addClass('active-filter');
                else $('#stat-total').closest('.stats-card-premium').addClass('active-filter');
            }

            $('#SearchCourseId').change(function () {
                loadStudentRegistrations();
            });

            // Status Card Click Handlers
            $('.stats-card-premium').click(function() {
                $('.stats-card-premium').removeClass('active-filter');
                $(this).addClass('active-filter');
                
                var cardId = $(this).find('h3').attr('id');
                if (cardId === 'stat-pending') selectedStatus = 1;
                else if (cardId === 'stat-approved') selectedStatus = 2;
                else if (cardId === 'stat-rejected') selectedStatus = 3;
                else selectedStatus = 0; // Total
                
                loadStudentRegistrations();
            });

            $.getJSON('/AdminPortal/StudentRegistration/GetCourseListJsonResult', function (data) {
                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();
                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            $('#btnNewStudentRegister').on('click', function () {
                var url = $(this).data('action-url');
                window.location.href = url;
            });

            loadStudentRegistrations();
            loadRegistrationStats();

        });

        function loadRegistrationStats() {
            $.getJSON('/AdminPortal/StudentRegistration/GetRegistrationStats', function (data) {
                $('#stat-pending').text(data.pending);
                $('#stat-approved').text(data.approved);
                $('#stat-rejected').text(data.rejected);
                $('#stat-total').text(data.total);
            });
        }

        function loadStudentRegistrations() {

            if ($.fn.DataTable.isDataTable('#StudentRegistrationDataTable')) {
                $('#StudentRegistrationDataTable').DataTable().clear().destroy();
                $('#StudentRegistrationDataTable tbody').empty();
            }

            $('#StudentRegistrationDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                columnDefs: [
                    { targets: [2, 3, 4, 5], className: 'hide-mobile' },
                    { targets: 0, className: 'noVis ps-3' },
                    { targets: 6, className: 'text-center' },
                    { width: 40, targets: 0, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/StudentRegistration/ListOfStudentRegistrations',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                        d.status = selectedStatus;
                    }
                },
                columns: [
                    {
                        data: null,
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            var approveUrl = `/AdminPortal/StudentRegistration/Approve/?q=${row.encryptedKey}`;
                            var rejectUrl = `/AdminPortal/StudentRegistration/Reject/?q=${row.encryptedKey}`;
                            var detailsUrl = `/AdminPortal/StudentRegistration/Details/?q=${row.encryptedKey}`;
                            var isFinalized = row.isApproved; 
                            var isRejected = row.isRejected;

                            var approveBtn = `<button class="btn btn-sm btn-soft-success p-1 px-2 rounded-pill approve-registration" data-action-url="${approveUrl}" title="Approve Admission">
                                                <i data-feather="check-circle" style="width: 14px; height: 14px;"></i>
                                              </button>`;
                            
                            var viewBtn = `<button class="btn btn-sm btn-soft-info p-1 px-2 rounded-pill view-registration-details" data-action-url="${detailsUrl}" title="View Details">
                                                <i data-feather="eye" style="width: 14px; height: 14px;"></i>
                                           </button>`;

                            var moreBtn = `
                                <div class="dropdown d-inline-block ms-1">
                                    <button class="btn btn-sm btn-light border-0 p-1 rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 32px; height: 32px;">
                                        <i data-feather="more-vertical" style="width: 16px; height: 16px;"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 0.75rem; min-width: 180px;">
                                        <li><h6 class="dropdown-header smaller text-muted fw-bold">MORE ACTIONS</h6></li>
                                        <li><a class="dropdown-item d-flex align-items-center gap-2 text-danger ${isFinalized ? 'disabled opacity-50' : 'reject-registration'}" href="javascript:void(0)" data-action-url="${rejectUrl}" data-action-parameter="${row.studentRegistrationPopulatedName}"><i data-feather="x-circle" style="width: 14px; height: 14px;"></i><span>Reject admission</span></a></li>
                                    </ul>
                                </div>`;

                            return `<div class="d-flex justify-content-center align-items-center gap-1">
                                        ${viewBtn}
                                        ${(!isFinalized && !isRejected) ? approveBtn : ''}
                                        ${moreBtn}
                                    </div>`;
                        }
                    },
                    { 
                        data: 'studentRegistrationPopulatedName', 
                        name:'studentRegistrationPopulatedName',
                        render: function(data, type, row) {
                            var detailsUrl = `/AdminPortal/StudentRegistration/Details/?q=${row.encryptedKey}`;
                            var initial = data.substring(0, 1).toUpperCase();
                            return `
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle">${initial}</div>
                                    <div>
                                        <div class="fw-bold text-dark"><a href="javascript:void(0)" class="text-dark text-decoration-none view-registration-details" data-action-url="${detailsUrl}">${data}</a></div>
                                        <div class="text-muted smaller">${row.email}</div>
                                    </div>
                                </div>`;
                        }
                    },
                    { data: 'course.courseName', name:'course.courseName' },
                    { data: 'studentLearningMode.learningModeName', name:'studentLearningMode.learningModeName' },
                    { 
                        data: 'phoneNo', 
                        name: 'phoneNo',
                        render: function(data, type, row) {
                            return `<div class="text-dark fw-600 small"><i class="fas fa-phone me-1 text-muted smaller"></i> ${data}</div>`;
                        }
                    },
                    { data: 'createdDateTime', name:'createdDateTime', render: function (data) { return `<div class="text-muted small">${renderDateOnly(data)}</div>`; } },
                    { 
                        data: null, 
                        name: 'status', 
                        orderable: false, 
                        render: function (data, type, row) {
                            if (row.isApproved) {
                                return `<span class="badge badge-premium bg-soft-success text-success border-0 rounded-pill">APPROVED</span>`;
                            }
                            if (row.isRejected) {
                                return `<span class="badge badge-premium bg-soft-danger text-danger border-0 rounded-pill">REJECTED</span>`;
                            }
                            return `<span class="badge badge-premium bg-soft-warning text-warning border-0 rounded-pill">PENDING</span>`;
                        }
                    }
                ],
                drawCallback: function (settings) {
                    if (window.feather) { feather.replace(); }
                    approveButton();
                    rejectButton();
                    viewDetailsButton();

                    loadRegistrationStats();
                }
            });
        }

        function renderDateOnly(data) {
            if (!data) return '';
            return data.split('T')[0];
        }

    </script>

}
