@using SENSEI.DOMAIN
@using core_web.Helpers
@model Batch

@{
    ViewData["Title"] = "Batch Management";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Batches</h1>
            <p class="text-muted small mb-0">Organize and manage student learning groups.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewBatch" data-action-url="/AdminPortal/Batch/Create">
            <i class="fas fa-plus me-2"></i> New Batch
        </button>
    </div>

    <!-- Stats Overview -->
    <div class="row mb-4 g-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid var(--sensei-red) !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-primary text-primary rounded-circle p-2 me-3">
                        <i data-feather="users" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Total Batches</h6>
                        <h4 class="fw-900 mb-0" id="stat-total-batches">...</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-radius: 1rem; border-left: 4px solid #03a9f3 !important;">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-soft-info text-info rounded-circle p-2 me-3">
                        <i data-feather="play-circle" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase mb-0">Starting Soon</h6>
                        <h4 class="fw-900 mb-0" id="stat-starting">...</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
        <div class="card-body p-4">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fas fa-filter"></i>
                    </div>
                </div>
                <div class="col">
                    <h5 class="mb-0 fw-800">Batch Filter</h5>
                    <p class="text-muted small mb-0">Select a course to view its specific batches.</p>
                </div>
                <div class="col-md-4">
                    <div class="d-flex gap-2">
                        <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-white"></select>
                        <button type="button" class="btn btn-light rounded-pill px-3 shadow-sm" id="btnClearFilters" title="Reset Filters">
                            <i class="fas fa-undo text-muted"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom">
            <h5 class="card-title mb-0 fw-800">Available Batches</h5>
        </div>
        <div class="card-body p-0">
            <div id="BatchTableContent" class="table-responsive">
                <table id="BatchDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th style="display:none;">ID</th>
                            <th class="ps-4" style="width: 80px;"></th>
                            <th>Course</th>
                            <th>Batch Name</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("BatchOffCanvas", "Batch", new { area = "AdminPortal" })

@section Scripts {

    <script src="~/js/admin-portal/batch-function.js"></script>

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                loadBatches();
            });

            $('#btnClearFilters').click(function () {
                $('#SearchCourseId').val('0').trigger('change');
            });

            $.getJSON('/AdminPortal/Batch/GetCourseListJsonResult', function (data) {
                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();
                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            loadBatches();

        });

        function loadBatches() {

            if ($.fn.DataTable.isDataTable('#BatchDataTable')) {
                $('#BatchDataTable').DataTable().clear().destroy();
                $('#BatchDataTable tbody').empty();
            }

            $('#BatchDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                order: [[0, "desc"]], // New Batches First
                columnDefs: [
                    { targets: 0, visible: false }, // Hide ID
                    { targets: 1, className: 'noVis ps-3' },
                    { width: 80, targets: 1, orderable: false },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/Batch/ListOfBatches',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                    }
                },
                columns: [
                    { data: 'batchId', name: 'batchId' },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            var editUrl = `/AdminPortal/Batch/Edit/?q=${row.encryptedKey}`;
                            var deleteUrl = `/AdminPortal/Batch/Delete/?q=${row.encryptedKey}`;

                            return `
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-soft-primary p-1 px-2 rounded-pill edit-batch" data-action-url="${editUrl}" title="Edit Batch">
                                        <i data-feather="edit" style="width: 14px; height: 14px;"></i>
                                    </button>
                                    <button class="btn btn-sm btn-soft-danger p-1 px-2 rounded-pill delete-batch" data-action-url="${deleteUrl}" data-action-parameter="${row.batchName}" title="Delete Batch">
                                        <i data-feather="trash-2" style="width: 14px; height: 14px;"></i>
                                    </button>
                                </div>`;
                        }
                    },
                    { 
                        data: 'course.courseName', 
                        name:'course.courseName',
                        render: function(data) { return `<div class="fw-800 text-primary" style="font-size: 0.95rem;">${data}</div>`; }
                    },
                    { data: 'batchName', name:'batchName', render: function(data) { return `<span class="badge bg-soft-info text-info fw-bold px-3 py-1 rounded-pill" style="font-size: 0.75rem;">${data}</span>`; } },
                    { data: 'batchStartDate', name:'batchStartDate', render: function (data) { return `<div class="text-dark fw-600" style="font-size: 0.9rem;"><i class="far fa-calendar-alt me-1 text-primary"></i> ${renderDateOnly(data)}</div>`; } },
                    { data: 'batchEndDate', name:'batchEndDate', render: function (data) { return `<div class="text-secondary small fw-500"><i class="far fa-calendar-check me-1"></i> ${renderDateOnly(data)}</div>`; } },
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }

                    // Calculate stats
                    var tableData = $('#BatchDataTable').DataTable().rows().data();
                    var total = tableData.length;
                    var startingSoon = 0;
                    var now = new Date();
                    var nextMonth = new Date();
                    nextMonth.setDate(now.getDate() + 30);

                    tableData.each(function(row) {
                        var startDate = new Date(row.batchStartDate);
                        if (startDate >= now && startDate <= nextMonth) startingSoon++;
                    });

                    $('#stat-total-batches').text(total);
                    $('#stat-starting').text(startingSoon);

                    editBatchButton();
                    deleteBatchButton();
                }
            });
        }

        function renderDateOnly(data) {
            if (!data) return '—';
            return data.split('T')[0];
        }

    </script>

}
