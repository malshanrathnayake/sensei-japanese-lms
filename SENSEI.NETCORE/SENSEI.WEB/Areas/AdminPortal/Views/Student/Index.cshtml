@using SENSEI.DOMAIN
@using core_web.Helpers
@model Student

@{
    ViewData["Title"] = "Student Registration";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Student</h1>

        <button type="button" class="btn btn-primary" id="btnNewStudentRegister" data-action-url="/AdminPortal/StudentRegistration/Create">
            <i class="fas fa-plus"></i> New
        </button>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Search By</h5>
                </div>
                <div class="card-body">

                    <div class="row">
                        <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12 col-xm-12">
                            <div class="mb-3" id="search-course-wrapper">
                                <label class="form-label">@Html.DisplayNameFor(m => m.StudentBatches.FirstOrDefault().Batch.CourseId)</label>
                                <select id="SearchCourseId" class="form-control search-course-select" name="SearchCourseId"></select>
                                @* <span asp-validation-for="CourseId" class="text-danger"></span> *@
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">List of Student Registrations</h5>
                </div>
                <div class="card-body">

                    <div id="StudentTableContent" class="table-responsive">

                        <table id="StudentDataTable" class="table table-hover align-middle mb-0 w-100">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>@Html.DisplayNameFor(m => m.StudentPopulatedName)</th>
                                    <th>@Html.DisplayNameFor(m => m.StudentBatches.FirstOrDefault().Batch.CourseId)</th>
                                    <th>@Html.DisplayNameFor(m => m.StudentBatches.FirstOrDefault().Batch.BatchName)</th>
                                    <th>@Html.DisplayNameFor(m => m.IndexNumber)</th>
                                    <th>@Html.DisplayNameFor(m => m.StudentLearningMode.LearningModeName)</th>
                                    <th>@Html.DisplayNameFor(m => m.Email)</th>
                                    <th>@Html.DisplayNameFor(m => m.PhoneNo)</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>

                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                var courseId = $(this).val();

                console.log(courseId);

                loadStudents();
            });


            $.getJSON('/AdminPortal/Student/GetCourseListJsonResult', function (data) {

                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();

                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            $('#btnNewStudentRegister').on('click', function () {
                var url = $(this).data('action-url');
                window.location.href = url;
            });

            loadStudents();

        });

        function loadStudents() {

            if ($.fn.DataTable.isDataTable('#StudentDataTable')) {
                $('#StudentDataTable').DataTable().clear().destroy();
                $('#StudentDataTable tbody').empty();
            }

            $('#StudentDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                columnDefs: [
                    { targets: 0, className: 'noVis' },
                    { width: 25, targets: 0, orderable: false },
                ],
                dom:
                    "<'row mb-3'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row mt-3'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/Student/ListOfStudents',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                    }
                },
                columns: [
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        width: "25px",
                        className: "text-end",
                        render: function (data, type, row) {
                            return ``;
                        }
                    },
                    { data: 'studentPopulatedName', name:'studentPopulatedName' },
                    { data: 'studentBatches.0.batch.course.courseName', name:'courseName' },
                    { data: 'studentBatches.0.batch.batchName', name:'batchName' },
                    { data: 'indexNumber', name:'indexNumber' },
                    { data: 'studentLearningMode.learningModeName', name:'studentLearningMode.learningModeName' },
                    { data: 'email', name:'email' },
                    { data: 'phoneNo', name:'phoneNo' }

                ],
                drawCallback: function () {

                    if (window.feather) {
                        feather.replace();
                    }
                }
            });

        }


    </script>

}
