@using SENSEI.DOMAIN
@using core_web.Helpers
@model Student

@{
    ViewData["Title"] = "Student Management";
}

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Students</h1>
            <p class="text-muted small mb-0">View student accounts and filtering options.</p>
        </div>

        <button type="button" class="btn btn-primary px-4 rounded-pill shadow-sm" id="btnNewStudentRegister" data-action-url="/AdminPortal/StudentRegistration/Create">
            <i class="fas fa-plus me-2"></i> Register New Student
        </button>
    </div>

    <!-- Search Section -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3">
            <h5 class="card-title mb-0 fw-800"><i class="fas fa-filter me-2 text-primary"></i> Filter Students</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-700">Course</label>
                    <select id="SearchCourseId" class="form-control select2 search-course-select shadow-none border-light-subtle bg-light"></select>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-header bg-white py-3 border-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-800">Student List</h5>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="StudentTableContent" class="table-responsive">
                <table id="StudentDataTable" class="table table-hover align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Student Name</th>
                            <th>Course</th>
                            <th>Batch</th>
                            <th>Index Number</th>
                            <th>Mode</th>
                            <th>Contact</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@section Scripts {

    <script type="text/javascript">

        $(document).ready(function () {

            $('#SearchCourseId').change(function () {
                loadStudents();
            });

            $.getJSON('/AdminPortal/Student/GetCourseListJsonResult', function (data) {
                $('#SearchCourseId').empty();
                $('#SearchCourseId').append('<option value="0">All Courses</option>')

                loadSelectBox({
                    data: data,
                    className: 'search-course-select',
                    title: 'Select Course'
                });

                var courseId = $('#SearchCourseId').val();
                if (courseId) {
                    $('#SearchCourseId').val(courseId).trigger('change');
                }
            });

            $('#btnNewStudentRegister').on('click', function () {
                var url = $(this).data('action-url');
                window.location.href = url;
            });

            loadStudents();

        });

        function loadStudents() {

            if ($.fn.DataTable.isDataTable('#StudentDataTable')) {
                $('#StudentDataTable').DataTable().clear().destroy();
                $('#StudentDataTable tbody').empty();
            }

            $('#StudentDataTable').DataTable({
                processing: true,
                serverSide: true,
                autoWidth: false,
                lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                pageLength: 25,
                columnDefs: [
                    { targets: 0, className: 'ps-4 fw-bold' },
                ],
                dom:
                    "<'row p-3 mb-0'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                    "<'row'<'col-sm-12'tr>>" +
                    "<'row p-3 mt-0'<'col-sm-5'i><'col-sm-7'p>>",
                ajax: {
                    url: '/AdminPortal/Student/ListOfStudents',
                    type: 'POST',
                    data: function (d) {
                        d.courseId = $('#SearchCourseId').val() || 0;
                    }
                },
                columns: [
                    { 
                        data: 'studentPopulatedName', 
                        name:'studentPopulatedName',
                        render: function(data, type, row) {
                            return `<div class="text-dark">${data}</div><div class="text-muted smaller fw-normal">${row.email}</div>`;
                        }
                    },
                    { data: 'studentBatches.0.batch.course.courseName', name:'courseName' },
                    { data: 'studentBatches.0.batch.batchName', name:'batchName' },
                    { data: 'indexNumber', name:'indexNumber' },
                    { data: 'studentLearningMode.learningModeName', name:'studentLearningMode.learningModeName' },
                    { data: 'phoneNo', name:'phoneNo' }
                ],
                drawCallback: function () {
                    if (window.feather) { feather.replace(); }
                }
            });
        }

    </script>

}
