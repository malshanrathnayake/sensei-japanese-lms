@{
    ViewData["Title"] = "Student Dashboard";
    long totalCourses = ViewBag.TotalCourses ?? 0;
    var upcomingLessons = ViewBag.UpcomingLessons as IEnumerable<SENSEI.DOMAIN.BatchLesson> ?? new List<SENSEI.DOMAIN.BatchLesson>();
}

<div class="container-fluid p-0">
    <div class="row mb-3 mb-xl-4 align-items-center">
        <div class="col-auto d-none d-sm-block">
            <h3 class="fw-800 text-dark mb-0"><span style="color: var(--sensei-red);">Student</span> Dashboard</h3>
            <p class="text-muted small mb-0">Welcome back! Follow your Japanese learning journey.</p>
        </div>

        <div class="col-auto ms-auto text-end mt-n1">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mt-1 mb-0">
                    <li class="breadcrumb-item"><a href="#" class="text-muted">LMS</a></li>
                    <li class="breadcrumb-item active" aria-current="page" style="color: var(--sensei-red)">Dashboard</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Stat Cards Row -->
    <div class="row mb-4">
        <!-- Enrolled Courses -->
        <div class="col-12 col-md-6 d-flex">
            <div class="card flex-fill shadow-sm border-0 w-100">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col mt-0">
                            <h5 class="card-title text-uppercase small fw-800 mb-0" style="color: var(--sensei-red) !important; letter-spacing: 0.1em;">Enrolled Courses</h5>
                        </div>
                        <div class="col-auto">
                            <div class="stat d-flex align-items-center justify-content-center rounded-circle" style="width: 48px; height: 48px; background: rgba(216, 50, 54, 0.08); color: var(--sensei-red) !important;">
                                <i class="align-middle" data-feather="book-open" style="width: 24px; height: 24px;"></i>
                            </div>
                        </div>
                    </div>
                    <h1 class="mt-3 mb-1 fw-900" style="font-size: 2.5rem;">@totalCourses</h1>
                    <div class="mb-0">
                        <span class="text-muted small fw-600">Active enrollments across all batches</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Lessons -->
        <div class="col-12 col-md-6 d-flex">
            <div class="card flex-fill shadow-sm border-0 w-100">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col mt-0">
                            <h5 class="card-title text-uppercase small fw-800 mb-0" style="color: #2c3e50 !important; letter-spacing: 0.1em;">Total Lessons</h5>
                        </div>
                        <div class="col-auto">
                            <div class="stat d-flex align-items-center justify-content-center rounded-circle" style="width: 48px; height: 48px; background: rgba(44, 62, 80, 0.08); color: #2c3e50 !important;">
                                <i class="align-middle" data-feather="video" style="width: 24px; height: 24px;"></i>
                            </div>
                        </div>
                    </div>
                    <h1 class="mt-3 mb-1 fw-900" style="font-size: 2.5rem;">@(ViewBag.TotalLessons ?? 0)</h1>
                    <div class="mb-0">
                        <span class="text-muted small fw-600">Available learning materials</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xl-8 d-flex">
            <div class="card flex-fill w-100 shadow-sm border-0">
                <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="card-title fw-800 text-dark mb-0">My Lessons</h5>
                    <a href="@Url.Action("Index", "MyLearning")" class="btn btn-sm btn-outline-primary border-0 fw-700">View All <i data-feather="chevron-right" class="ms-1" style="width: 14px; height: 14px;"></i></a>
                </div>
                <div class="card-body px-4 pb-4 px-0 pt-0">
                    <div class="table-responsive">
                        <table class="table mb-0 table-hover align-middle">
                            <thead class="bg-light">
                                <tr>
                                    <th class="border-0 rounded-start text-muted text-uppercase small fw-bold">Lesson Details</th>
                                    <th class="border-0 text-muted text-uppercase small fw-bold">Batch</th>
                                    <th class="border-0 rounded-end text-end text-muted text-uppercase small fw-bold">Schedule</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (upcomingLessons.Any())
                                {
                                    foreach (var lesson in upcomingLessons)
                                    {
                                        <tr>
                                            <td class="py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="stat d-flex align-items-center justify-content-center rounded bg-light me-3" style="width: 40px; height: 40px;">
                                                        <i class="text-primary" data-feather="play-circle" style="width: 20px; height: 20px;"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-700 text-dark">@(lesson.Lesson?.LessonName ?? "Unknown Lesson")</div>
                                                        <div class="text-muted small fw-600">@(lesson.Lesson?.Description?.Length > 30 ? lesson.Lesson.Description.Substring(0, 30) + "..." : lesson.Lesson?.Description ?? "Learning session")</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3">
                                                <span class="badge bg-soft-primary text-primary fw-600">@(lesson.Batch?.BatchName ?? "Unknown Batch")</span>
                                            </td>
                                            <td class="text-end py-3">
                                                <div class="fw-700 text-dark">@lesson.LessonDateTime.ToString("MMM dd, yyyy")</div>
                                                <div class="text-muted small fw-600">@lesson.LessonDateTime.ToString("h:mm tt")</div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted p-5">
                                            <div class="mb-3">
                                                <i data-feather="calendar" style="width: 48px; height: 48px; opacity: 0.5;"></i>
                                            </div>
                                            <div class="fw-bold">No lessons found.</div>
                                            <div class="small mt-1">Visit My Learning area to enroll.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4 d-flex">
            <div class="card flex-fill shadow-sm border-0 w-100">
                <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4">
                    <h5 class="card-title fw-800 text-dark mb-0">Calendar</h5>
                </div>
                <div class="card-body p-4 pt-2">
                    <div id="calendar-dashboard" style="min-height: 400px;"></div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var calendarEl = document.getElementById('calendar-dashboard');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next',
                    center: 'title',
                    right: ''
                },
                height: 'auto',
                events: [
                    @foreach (var lesson in upcomingLessons)
                    {
                        <text>
                        {
                            title: '@(lesson.Lesson?.LessonName ?? "Lesson")',
                            start: '@lesson.LessonDateTime.ToString("yyyy-MM-ddTHH:mm:ss")',
                            backgroundColor: 'rgba(216, 50, 54, 0.1)',
                            textColor: '#D83236',
                            borderColor: 'transparent'
                        },
                        </text>
                    }
                ]
            });
            calendar.render();
        });
    </script>
}
