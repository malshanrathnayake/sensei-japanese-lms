@model SENSEI.DOMAIN.Student
@{
    ViewData["Title"] = "My Profile";
}

<style>
    /* Profile Premium Styling */
    .profile-card-premium {
        background: #ffffff;
        border: 1px solid rgba(216, 50, 54, 0.08);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }

    .profile-header-accent {
        height: 100px;
        background: linear-gradient(135deg, var(--sensei-red) 0%, var(--sensei-red-dark) 100%);
        position: relative;
    }

    .profile-avatar-wrapper {
        margin-top: -60px;
        position: relative;
        z-index: 2;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border: 5px solid #ffffff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        background: #fff;
    }

    .status-badge-premium {
        background: rgba(216, 50, 54, 0.08);
        color: var(--sensei-red);
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        display: inline-block;
    }

    .info-label {
        font-weight: 800;
        color: #adb5bd;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.25rem;
    }

    .info-value {
        font-weight: 700;
        color: #212529;
        font-size: 0.95rem;
    }

    /* Form refinement */
    .form-group-spaced {
        margin-bottom: 1.5rem;
    }

    .form-label-premium {
        font-weight: 800;
        color: #495057;
        font-size: 0.8rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    .btn-update-profile {
        padding: 0.8rem 2.5rem;
        border-radius: 12px;
        font-weight: 800;
        letter-spacing: 0.02em;
        box-shadow: 0 8px 15px rgba(216, 50, 54, 0.2);
    }
</style>

<div class="container-fluid p-0 sakura-bg">
    <div class="row mb-5 align-items-center">
        <div class="col-12 col-md-auto mb-3 mb-md-0">
            <h3 class="fw-900 text-dark mb-1">My <span style="color: var(--sensei-red);">Profile</span></h3>
            <p class="text-muted small mb-0 fw-600">Personalize your Japanese learning experience.</p>
        </div>
        <div class="col-md-auto ms-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home", new { area = "StudentPortal" })" class="text-muted fw-600">Dashboard</a></li>
                    <li class="breadcrumb-item active text-dark fw-700" aria-current="page">Profile</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <!-- Left Column: User Summary -->
        <div class="col-12 col-xl-4 mb-4">
            <div class="profile-card-premium text-center pb-5">
                <div class="profile-header-accent"></div>
                <div class="profile-avatar-wrapper">
                    <img src="@(Context.Session.GetString("ProfileImage") ?? "/theme/v1/img/avatars/placeholder_1.jpeg")" 
                         class="rounded-circle profile-avatar" 
                         alt="Avatar">
                </div>
                
                <div class="px-4 mt-3">
                    <h4 class="fw-900 text-dark mb-1">@(Model?.StudentPopulatedName ?? "N/A")</h4>
                    <div class="text-muted small fw-700 mb-3">ID: @(Model?.IndexNumber ?? "N/A")</div>
                    
                    <div class="status-badge-premium mb-4">OFFICIAL STUDENT</div>
                    
                    <hr class="my-4 opacity-5">
                    
                    <div class="row g-4 text-start">
                        <div class="col-6">
                            <div class="info-label">Branch</div>
                            <div class="info-value">@(Model?.Branch?.BranchName ?? "N/A")</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Mode</div>
                            <div class="info-value">@(Model?.StudentLearningMode?.LearningModeName ?? "N/A")</div>
                        </div>
                        <div class="col-12">
                            <div class="info-label">Current Status</div>
                            <div class="d-flex align-items-center">
                                <span class="bg-success rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                                <div class="info-value">Active Learner</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Edit Details -->
        <div class="col-12 col-xl-8">
            <div class="profile-card-premium">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-900 text-dark mb-0">Personal Information</h5>
                </div>
                <div class="card-body p-4">
                    <form id="profileForm" asp-action="UpdateProfile" method="post">
                        <input type="hidden" asp-for="StudentId" />
                        <div class="row">
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">First Name</label>
                                <input type="text" class="form-control" asp-for="FirstName" placeholder="Enter first name" required>
                            </div>
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">Last Name</label>
                                <input type="text" class="form-control" asp-for="LastName" placeholder="Enter last name" required>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i data-feather="mail" class="feather-sm"></i></span>
                                    <input type="email" class="form-control bg-light" asp-for="Email" readonly>
                                </div>
                                <small class="text-muted mt-2 d-block px-1" style="font-size: 0.75rem;"><i data-feather="info" class="feather-xs me-1"></i> Email cannot be modified.</small>
                            </div>
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i data-feather="phone" class="feather-sm text-muted"></i></span>
                                    <input type="text" class="form-control ps-1" asp-for="PhoneNo" placeholder="+94 XX XXX XXXX" required>
                                </div>
                            </div>
                        </div>

                        <div class="row border-top pt-4 mt-2">
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">NIC / Identity Number</label>
                                <input type="text" class="form-control" asp-for="NIC" placeholder="Identity number" required>
                            </div>
                            <div class="col-md-6 form-group-spaced">
                                <label class="form-label-premium">Date of Birth</label>
                                <input type="text" class="form-control bg-light" value="@Model?.DateOfBirth.ToString("MMM dd, yyyy")" readonly>
                            </div>
                        </div>
                        
                        <div class="text-end pt-4 mt-2">
                             <button type="submit" class="btn btn-primary btn-update-profile px-5">
                                 <i class="align-middle me-2" data-feather="check-circle" style="width: 18px; height: 18px;"></i> Save Changes
                             </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script>
        $(document).ready(function() {
            if (window.feather) { feather.replace(); }

            $("#profileForm").validate({
                rules: {
                    FirstName: "required",
                    LastName: "required",
                    PhoneNo: { required: true, minlength: 10 },
                    NIC: "required"
                },
                messages: {
                    FirstName: "Please enter your first name",
                    LastName: "Please enter your last name",
                    PhoneNo: "Valid phone number required",
                    NIC: "NIC is required"
                },
                errorElement: 'div',
                errorClass: 'invalid-feedback d-block',
                highlight: function(element) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid');
                }
            });

            @if (TempData["Success"] != null)
            {
                <text>popUpNotification('success', "@TempData["Success"]");</text>
            }
        });
    </script>
}
