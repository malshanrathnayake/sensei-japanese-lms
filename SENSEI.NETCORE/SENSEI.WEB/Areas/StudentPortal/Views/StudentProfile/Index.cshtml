@model SENSEI.DOMAIN.Student
@{
    ViewData["Title"] = "My Profile";
}

<style>
    /* Premium Student Profile Styling */
    .profile-card-premium {
        background: #ffffff;
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .profile-card-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(216, 50, 54, 0.08);
    }

    .profile-header-accent {
        height: 120px;
        background: linear-gradient(135deg, #d83236 0%, #a01f22 100%);
        position: relative;
    }

    .profile-avatar-wrapper {
        margin-top: -60px;
        position: relative;
        z-index: 2;
    }

    .profile-avatar {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border: 6px solid #ffffff;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        background: #fff;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .profile-avatar:hover {
        transform: scale(1.05);
    }

    .status-pill {
        background: rgba(40, 167, 69, 0.1);
        color: #28a745;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .id-badge {
        background: #f8f9fa;
        color: #6c757d;
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid #eee;
    }

    .info-label {
        font-weight: 800;
        color: #adb5bd;
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 700;
        color: #2b2f33;
        font-size: 0.9rem;
    }

    .section-header-premium {
        font-weight: 900;
        color: #2b2f33;
        font-size: 1.1rem;
        letter-spacing: -0.01em;
        position: relative;
        padding-bottom: 12px;
        margin-bottom: 25px;
    }

    .section-header-premium::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 40px;
        height: 4px;
        background: var(--sensei-red);
        border-radius: 2px;
    }

    .btn-update-profile {
        padding: 1rem 3rem;
        border-radius: 16px;
        font-weight: 800;
        font-size: 1rem;
        transition: all 0.3s;
        background: var(--sensei-red);
        border: none;
        box-shadow: 0 10px 20px rgba(216, 50, 54, 0.2);
    }

    .btn-update-profile:hover {
        background: #b52528;
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(216, 50, 54, 0.3);
        color: #fff;
    }

    .form-floating > label {
        font-weight: 700;
        color: #adb5bd;
    }

    .input-group-text-premium {
        background: #f8f9fa;
        border: 2px solid #f8f9fa;
        border-right: none;
        color: #adb5bd;
        border-radius: 12px 0 0 12px !important;
    }

    .form-control-premium {
        border-radius: 12px !important;
        padding: 0.75rem 1rem !important;
        border: 2px solid #f8f9fa !important;
        background: #f8f9fa !important;
        font-weight: 700 !important;
        color: #2b2f33 !important;
        transition: all 0.2s ease;
    }

    .form-control-premium:focus {
        background: #fff !important;
        border-color: var(--sensei-red) !important;
        box-shadow: 0 0 0 4px rgba(216, 50, 54, 0.05) !important;
    }

    .form-control-premium[readonly] {
        background: #f1f3f5 !important;
        color: #adb5bd !important;
        cursor: not-allowed;
    }
</style>

<div class="container-fluid p-0 sakura-bg">
    <!-- Header Section -->
    <div class="row mb-5 align-items-center animate__animated animate__fadeIn">
        <div class="col-md-auto">
            <h2 class="fw-900 text-dark mb-1">My <span class="text-primary">Profile</span></h2>
            <p class="text-muted small fw-600 mb-0">Customize your digital Zen space.</p>
        </div>
        <div class="col-md-auto ms-auto d-none d-md-block">
            <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill fw-bold">
                Level: N5 Student
            </span>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Column: Summary & Quick Info -->
        <div class="col-12 col-xl-4 mb-4 animate__animated animate__fadeInUp">
            <div class="profile-card-premium text-center pb-5">
                <div class="profile-header-accent">
                    <div class="position-absolute top-0 end-0 p-3 opacity-10">
                        <i data-feather="settings" class="text-white" style="width: 80px; height: 80px;"></i>
                    </div>
                </div>
                
                <div class="profile-avatar-wrapper">
                    <img src="@(Context.Session.GetString("ProfileImage") ?? "/theme/v1/img/avatars/placeholder_1.jpeg")" 
                         class="rounded-circle profile-avatar" 
                         alt="Avatar">
                </div>
                
                <div class="px-4 mt-3">
                    <h4 class="fw-900 text-dark mb-1">@(Model?.StudentPopulatedName ?? "N/A")</h4>
                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <span class="id-badge">ID: @(Model?.IndexNumber ?? "N/A")</span>
                        <span class="status-pill">OFFICIAL</span>
                    </div>
                    
                    <div class="p-3 bg-light rounded-4 mb-4 d-flex justify-content-around">
                        <div class="text-center px-2 border-end border-white">
                            <div class="info-label">Branch</div>
                            <div class="info-value">@(Model?.Branch?.BranchName ?? "N/A")</div>
                        </div>
                        <div class="text-center px-2">
                            <div class="info-label">Learning Mode</div>
                            <div class="info-value">@(Model?.StudentLearningMode?.LearningModeName ?? "N/A")</div>
                        </div>
                    </div>

                    <div class="row g-3 text-start mt-2">
                        <div class="col-12">
                            <div class="d-flex align-items-center p-3 border rounded-4 bg-white border-light shadow-sm">
                                <div class="bg-soft-success text-success p-2 rounded-3 me-3">
                                    <i data-feather="check-circle" style="width: 18px; height: 18px;"></i>
                                </div>
                                <div>
                                    <div class="info-label m-0">Account Status</div>
                                    <div class="info-value text-success mt-n1">Active Learner</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Column: Detail Form -->
        <div class="col-12 col-xl-8 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
            <div class="profile-card-premium h-100">
                <div class="card-body p-4 p-md-5">
                    <h5 class="section-header-premium">Personal Information</h5>
                    
                    <form id="profileForm" asp-action="UpdateProfile" method="post">
                        <input type="hidden" asp-for="StudentId" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="IndexNumber" />
                        <input type="hidden" asp-for="DateOfBirth" />
                        <input type="hidden" asp-for="CountryId" />
                        <input type="hidden" asp-for="BranchId" />
                        <input type="hidden" asp-for="StudentLearningModeId" />
                        <input type="hidden" asp-for="City" />

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="info-label">First Name</label>
                                <input type="text" class="form-control form-control-premium" asp-for="FirstName" placeholder="Santhushie" required>
                            </div>
                            <div class="col-md-6">
                                <label class="info-label">Last Name</label>
                                <input type="text" class="form-control form-control-premium" asp-for="LastName" placeholder="Nallaperuma" required>
                            </div>
                        </div>
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="info-label">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light"><i data-feather="mail" style="width: 16px; height: 16px;"></i></span>
                                    <input type="email" class="form-control form-control-premium" asp-for="Email" readonly>
                                </div>
                                <div class="mt-2 text-muted smaller" style="font-size: 0.7rem;">
                                    <i data-feather="lock" class="me-1" style="width: 10px; height: 10px;"></i> Email is linked to Google SSO and cannot be changed.
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="info-label">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light"><i data-feather="phone" style="width: 16px; height: 16px;"></i></span>
                                    <input type="text" class="form-control form-control-premium" asp-for="PhoneNo" placeholder="+94 XX XXX XXXX" required>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4 mb-5 border-top pt-4 mt-2">
                            <div class="col-md-6">
                                <label class="info-label">NIC / Identity Number</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light"><i data-feather="hash" style="width: 16px; height: 16px;"></i></span>
                                    <input type="text" class="form-control form-control-premium" asp-for="NIC" placeholder="Identity number" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="info-label">Date of Birth</label>
                                <div class="input-group">
                                    <span class="input-group-text border-0 bg-light"><i data-feather="calendar" style="width: 16px; height: 16px;"></i></span>
                                    <input type="text" class="form-control form-control-premium" value="@Model?.DateOfBirth.ToString("MMM dd, yyyy")" readonly>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mt-4">
                             <button type="submit" class="btn btn-primary btn-update-profile w-100 w-md-auto" id="btnSaveProfile">
                                 <i class="me-2" data-feather="save" style="width: 20px; height: 20px;"></i> Save Changes
                             </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script>
        $(document).ready(function() {
            if (window.feather) { feather.replace(); }

            $("#profileForm").validate({
                rules: {
                    FirstName: "required",
                    LastName: "required",
                    PhoneNo: { required: true, minlength: 10 },
                    NIC: "required"
                },
                messages: {
                    FirstName: "Please enter your first name",
                    LastName: "Please enter your last name",
                    PhoneNo: "Valid phone number required",
                    NIC: "NIC is required"
                },
                errorElement: 'div',
                errorClass: 'invalid-feedback fw-bold small mt-1 d-block',
                highlight: function(element) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function(element) {
                    $(element).removeClass('is-invalid');
                }
            });

            @if (TempData["Success"] != null) {
                <text>popUpNotification('success', "@TempData["Success"]");</text>
            }
            @if (TempData["Error"] != null) {
                <text>popUpNotification('error', "@TempData["Error"]");</text>
            }
        });
    </script>
}
