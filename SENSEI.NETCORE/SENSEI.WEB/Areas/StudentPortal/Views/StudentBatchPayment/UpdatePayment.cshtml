@using SENSEI.DOMAIN
@model StudentBatchPayment

@{
    Layout = null;
}

<style>
    /* Premium Offcanvas Refinements */
    #studentbatchpaymentOffcanvas {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        border-left: 1px solid rgba(216, 50, 54, 0.1);
        box-shadow: -15px 0 50px rgba(0, 0, 0, 0.08) !important;
        width: 420px !important;
        border-radius: 30px 0 0 30px !important;
    }

    .payment-upload-card {
        background: #ffffff;
        border: 2px dashed rgba(216, 50, 54, 0.15);
        border-radius: 20px;
        padding: 40px 20px;
        text-align: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .payment-upload-card:hover {
        border-color: var(--sensei-red);
        background: #fffafa;
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(216, 50, 54, 0.08);
    }

    .payment-upload-card.has-file {
        border-style: solid;
        border-color: #27ae60;
        background: #f8fff9;
    }

    .upload-icon-circle {
        width: 70px;
        height: 70px;
        background: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(216, 50, 54, 0.12);
        color: var(--sensei-red);
        transition: all 0.3s ease;
    }

    .payment-upload-card:hover .upload-icon-circle {
        transform: scale(1.1) rotate(5deg);
        background: var(--sensei-red);
        color: #fff;
    }

    .slip-preview-container {
        display: none;
        margin-top: 20px;
        position: relative;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        border: 4px solid #fff;
    }

    .slip-preview-container img {
        width: 100%;
        max-height: 250px;
        object-fit: contain;
        background: #f8f9fa;
    }

    .remove-slip-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255, 255, 255, 0.9);
        border: none;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #e74c3c;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        cursor: pointer;
        z-index: 5;
    }

    .form-label-premium {
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #495057;
        margin-bottom: 0.6rem;
        display: block;
    }

    .input-premium {
        border-radius: 15px !important;
        padding: 0.9rem 1.25rem !important;
        border: 1px solid rgba(0,0,0,0.08) !important;
        font-weight: 700 !important;
        background: #fdfdfd !important;
        transition: all 0.3s ease !important;
    }

    .input-premium:focus {
        border-color: var(--sensei-red) !important;
        background: #fff !important;
        box-shadow: 0 0 0 5px rgba(216, 50, 54, 0.08) !important;
    }

    .btn-action-submit {
        background: linear-gradient(135deg, var(--sensei-red) 0%, #a11d21 100%) !important;
        color: #fff !important;
        border: none !important;
        padding: 1.1rem !important;
        border-radius: 18px !important;
        font-weight: 800 !important;
        width: 100%;
        box-shadow: 0 12px 30px rgba(216, 50, 54, 0.3) !important;
        transition: all 0.3s ease !important;
    }

    .btn-action-submit:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 45px rgba(216, 50, 54, 0.45) !important;
    }
</style>

<div class="offcanvas-header p-4 pb-2 border-0">
    <div class="d-flex align-items-center">
        <div class="bg-soft-primary rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 52px; height: 52px; color: var(--sensei-red);">
            <i data-feather="plus-circle" style="width: 24px; height: 24px;"></i>
        </div>
        <div>
            <h5 class="offcanvas-title fw-900 text-dark mb-0" style="font-size: 1.25rem;">New Payment</h5>
            <p class="text-muted small mb-0 fw-600">Register your learning fee slip</p>
        </div>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
</div>

<div class="offcanvas-body p-4 pt-1">

    <form id="studentbatchpayment-create-form" asp-area="StudentPortal" asp-controller="StudentBatchPayment" asp-action="UpdatePayment"
          data-ajax="true" data-ajax-method="POST" enctype="multipart/form-data"
          data-ajax-begin="onPaymentCreateBegin" data-ajax-success="onPaymentCreateSuccess" data-ajax-failure="onPaymentCreateFailure" data-ajax-complete="onPaymentCreateComplete" >

        <div class="mb-4">
            <label class="form-label-premium">1. Select Course / Batch</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted rounded-start-4 ps-3 pe-0" style="border: 1px solid rgba(0,0,0,0.08); border-right: 0;"><i data-feather="book" style="width: 16px;"></i></span>
                <select id="StudentBatchId" name="StudentBatchId" class="form-control input-premium border-start-0" required>
                    <option value="">-- Select Enrolled Course --</option>
                    @if (ViewBag.StudentBatches != null)
                    {
                        foreach (var batch in ViewBag.StudentBatches)
                        {
                            <option value="@batch.id">@batch.text</option>
                        }
                    }
                </select>
            </div>
            <span asp-validation-for="StudentBatchId" class="text-danger small mt-1 d-block fw-600"></span>
        </div>

        <div class="mb-4 animate-fade-in" id="ssw-module-section" style="display: none;">
            <label class="form-label-premium" style="color: var(--sensei-red);">2. Select Module / Category</label>
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0 text-muted rounded-start-4 ps-3 pe-0" style="border: 1px solid rgba(0,0,0,0.08); border-right: 0;"><i data-feather="tag" style="width: 16px;"></i></span>
                <select asp-for="LessonId" id="LessonId" class="form-control input-premium border-start-0">
                    <option value="">Full Course Access (Standard)</option>
                </select>
            </div>
            <small class="text-muted mt-2 d-block fw-600 bg-soft-danger p-2 rounded-3" style="color: var(--sensei-red);">
                <i data-feather="info" class="me-1" style="width: 12px;"></i> 
                <strong>SSW Students:</strong> If you are paying for a specific module (e.g. Nursing, Food Service), please select it here. If not, keep it as "Full Course Access".
            </small>
        </div>

        <div class="row">
            <div class="col-md-6 mb-4">
                <label class="form-label-premium">3. Amount Paid (LKR)</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted rounded-start-4 ps-3 pe-0" style="border: 1px solid rgba(0,0,0,0.08); border-right: 0;"><i data-feather="dollar-sign" style="width: 16px;"></i></span>
                    <input type="number" step="0.01" class="form-control input-premium border-start-0" asp-for="Amount" placeholder="0.00" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small mt-1 d-block fw-600"></span>
            </div>
            <div class="col-md-6 mb-4">
                <label class="form-label-premium">4. For Which Month?</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted rounded-start-4 ps-3 pe-0" style="border: 1px solid rgba(0,0,0,0.08); border-right: 0;"><i data-feather="calendar" style="width: 16px;"></i></span>
                    <input type="text" class="form-control input-premium datepicker border-start-0" id="PaymentMonth" name="PaymentMonth" value="@Model.PaymentMonth.ToString("yyyy-MM")" autocomplete="off" placeholder="Select Month"/>
                </div>
                <span asp-validation-for="PaymentMonth" class="text-danger small mt-1 d-block fw-600"></span>
            </div>
        </div>

        <div class="mb-0">
            <label class="form-label-premium">5. Upload Payment Slip</label>
            
            <div class="payment-upload-card" id="drop-zone" onclick="document.getElementById('SlipImage').click()">
                <div id="upload-prompt">
                    <div class="upload-icon-circle">
                        <i data-feather="image" style="width: 28px; height: 28px;"></i>
                    </div>
                    <h6 class="fw-900 text-dark mb-1">Select Receipt Photo</h6>
                    <p class="text-muted small mb-0 px-3 fw-600">Ensure the date and amount are clearly visible</p>
                </div>

                <div class="slip-preview-container" id="preview-box">
                    <button type="button" class="remove-slip-btn" onclick="clearSelectedFile(event)">
                        <i data-feather="x" style="width: 16px; height: 16px;"></i>
                    </button>
                    <img id="image-preview" src="#" alt="Preview" />
                    <div class="bg-white p-2">
                        <span class="badge bg-soft-success text-success rounded-pill px-3 py-1 fw-700" id="file-name-badge">
                            <i data-feather="check" class="me-1" style="width: 12px;"></i> Ready
                        </span>
                    </div>
                </div>

                <input type="file" id="SlipImage" name="SlipImage" accept="image/*" class="d-none" onchange="handleFileUpload(this)" required />
            </div>
            
            <span asp-validation-for="SlipImage" class="text-danger small mt-2 d-block fw-600 text-center"></span>
        </div>

        <div class="mt-5">
            <button type="submit" class="btn btn-action-submit d-flex align-items-center justify-content-center" id="btnSavePayment">
                <span>Securely Submit Payment</span>
                <i class="ms-2" data-feather="lock" style="width: 18px;"></i>
            </button>
            <button type="button" class="btn btn-link w-100 text-muted small fw-800 mt-2 text-decoration-none" data-bs-dismiss="offcanvas">
                Cancel, go back
            </button>
        </div>

        <script>
            $(document).ready(function() {
                if (window.feather) { feather.replace(); }

                $('#StudentBatchId').on('change', function() {
                    var studentBatchId = $(this).val();
                    var dropdown = $('#LessonId');
                    var section = $('#ssw-module-section');
                    
                    dropdown.empty().append('<option value="">Full Course Access (Standard)</option>');

                    if (studentBatchId) {
                        $.getJSON('/StudentPortal/StudentBatchPayment/GetBatchLessons', { studentBatchId: studentBatchId }, function(data) {
                            if (data && data.length > 0) {
                                section.slideDown();
                                $.each(data, function(index, item) {
                                    dropdown.append($('<option>', {
                                        value: item.id,
                                        text: item.text
                                    }));
                                });
                            } else {
                                section.slideUp();
                            }
                        });
                    } else {
                        section.slideUp();
                    }
                });
            });
        </script>

    </form>

</div>

<script>
    function handleFileUpload(input) {
        const prompt = document.getElementById('upload-prompt');
        const previewBox = document.getElementById('preview-box');
        const previewImg = document.getElementById('image-preview');
        const fileNameBadge = document.getElementById('file-name-badge');
        const dropZone = document.getElementById('drop-zone');

        if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function(e) {
                previewImg.src = e.target.result;
                prompt.style.display = 'none';
                previewBox.style.display = 'block';
                dropZone.classList.add('has-file');
                fileNameBadge.innerHTML = `<i data-feather=\"check\" class=\"me-1\" style=\"width: 12px;\"></i> ${input.files[0].name.substring(0, 15)}...`;
                if (window.feather) { feather.replace(); }
            }

            reader.readAsDataURL(input.files[0]);
        }
    }

    function clearSelectedFile(e) {
        e.stopPropagation();
        const input = document.getElementById('SlipImage');
        const prompt = document.getElementById('upload-prompt');
        const previewBox = document.getElementById('preview-box');
        const dropZone = document.getElementById('drop-zone');
        
        input.value = '';
        prompt.style.display = 'block';
        previewBox.style.display = 'none';
        dropZone.classList.remove('has-file');
    }
</script>


