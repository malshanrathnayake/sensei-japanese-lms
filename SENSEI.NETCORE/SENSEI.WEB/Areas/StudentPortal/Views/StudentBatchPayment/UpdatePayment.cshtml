@using SENSEI.DOMAIN
@model StudentBatchPayment

@{
    Layout = null;
}

<div class="offcanvas-header bg-light border-bottom p-4">
    <div class="d-flex align-items-center">
        <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 42px; height: 42px; color: var(--sensei-red);">
            <i data-feather="dollar-sign" style="width: 20px; height: 20px;"></i>
        </div>
        <h5 class="offcanvas-title fw-800 text-dark mb-0">Add New Payment</h5>
    </div>
    <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
</div>

<div class="offcanvas-body p-4 bg-white">

    <form id="studentbatchpayment-create-form" asp-area="StudentPortal" asp-controller="StudentBatchPayment" asp-action="UpdatePayment"
          data-ajax="true" data-ajax-method="POST" enctype="multipart/form-data"
          data-ajax-begin="onPaymentCreateBegin" data-ajax-success="onPaymentCreateSuccess" data-ajax-failure="onPaymentCreateFailure" data-ajax-complete="onPaymentCreateComplete" >

        <input type="hidden" id="StudentBatchId" name="StudentBatchId" value="@Model.StudentBatchId" />

        <div class="alert alert-soft-primary bg-light border-0 rounded-4 p-3 mb-4 d-flex align-items-start">
            <i data-feather="info" class="me-2 text-muted mt-1" style="width: 18px; height: 18px;"></i>
            <div class="small text-muted">Please ensure your payment amount and selected month are accurate before submitting the payment slip for verification.</div>
        </div>

        <div class="mb-4">
            <label class="form-label fw-700 text-dark small text-uppercase letter-spacing-05">Amount Paid (Rs.) <span class="text-danger">*</span></label>
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-end-0 text-muted"><i data-feather="hash" style="width: 16px; height: 16px;"></i></span>
                <input type="number" step="0.01" class="form-control border-start-0 ps-0 fw-600" asp-for="Amount" placeholder="e.g. 5000.00" />
            </div>
            <span asp-validation-for="Amount" class="text-danger small mt-1 d-block fw-600"></span>
        </div>

        <div class="mb-4">
            <label class="form-label fw-700 text-dark small text-uppercase letter-spacing-05">Payment Month <span class="text-danger">*</span></label>
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-end-0 text-muted"><i data-feather="calendar" style="width: 16px; height: 16px;"></i></span>
                <input type="text" class="form-control datepicker border-start-0 ps-0 fw-600" asp-for="PaymentMonth" autocomplete="off" placeholder="Select month"/>
            </div>
            <span asp-validation-for="PaymentMonth" class="text-danger small mt-1 d-block fw-600"></span>
        </div>

        <div class="mb-4 p-4 border rounded-4 bg-light bg-opacity-50">
            <label class="form-label fw-700 small text-uppercase d-flex align-items-center mb-3" style="color: var(--sensei-red-dark)">
                <i data-feather="image" class="me-2" style="width: 16px; height: 16px;"></i> Payment Slip <span class="text-danger ms-1">*</span>
            </label>
            <div class="position-relative">
                <input type="file" class="form-control form-control-lg shadow-sm bg-white"
                       id="SlipImage" name="SlipImage" accept="image/*" required />
            </div>
            <div class="form-text mt-2 small text-muted d-flex align-items-center">
                <i data-feather="check-circle" class="me-1 text-success" style="width: 12px; height: 12px;"></i> Upload clear JPG/PNG/WebP image (max 5MB).
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top">
            <button type="button" class="btn btn-light border fw-600 px-4 shadow-sm" data-bs-dismiss="offcanvas">
                Cancel
            </button>

            <button type="submit" class="btn btn-primary fw-700 px-4 shadow-sm d-flex align-items-center" id="btnSavePayment">
                <i class="me-2" data-feather="upload-cloud" style="width: 18px; height: 18px;"></i> Submit Payment
            </button>
        </div>

    </form>

</div>


