@using core_web.Helpers
@model SENSEI.DOMAIN.Student

@{
    ViewData["Title"] = "My Payments";
}

<style>
    .error {
        color: var(--sensei-red);
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 4px;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--sensei-red) !important;
        box-shadow: 0 0 0 0.25rem rgba(216, 50, 54, 0.1) !important;
    }
    .table thead th {
        background: rgba(216, 50, 54, 0.02);
        color: var(--sensei-red-dark);
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        border-bottom: 2px solid rgba(216, 50, 54, 0.1);
    }
    .card.hover-elevate:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.08) !important;
    }
</style>

<div class="container-fluid p-0">

    <div class="row mb-3 mb-xl-4 align-items-center">
        <div class="col-auto d-none d-sm-block">
            <h3 class="fw-800 text-dark mb-0"><span style="color: var(--sensei-red);">My</span> Payments</h3>
            <p class="text-muted small mb-0">Student: <span class="fw-700">@Model?.StudentPopulatedName</span> (@Model?.IndexNumber)</p>
        </div>

        <div class="col-auto ms-auto text-end mt-n1">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mt-1 mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home", new { area = "StudentPortal" })" class="text-muted">LMS</a></li>
                    <li class="breadcrumb-item active" aria-current="page" style="color: var(--sensei-red)">Payments</li>
                </ol>
            </nav>
            <button class="btn btn-primary mt-2 shadow-sm" id="new-payment" data-action-url="@Url.Action("UpdatePayment", "StudentBatchPayment", new { area = "StudentPortal" })">
                <i class="align-middle me-1" data-feather="plus-circle"></i> New Payment
            </button>
        </div>
    </div>

    <!-- Summary Section -->
    <div class="row mb-4" id="summaryContainer">
        <!-- Summaries will be injected here via AJAX -->
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-transparent border-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="card-title fw-800 text-dark mb-0 d-flex align-items-center">
                        <i data-feather="list" class="me-2" style="color: var(--sensei-red);"></i> 
                        Payment History
                    </h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="table-responsive">
                        <table id="paymentTable" class="table table-hover align-middle w-100 mb-0" style="border-collapse: separate; border-spacing: 0 8px;">
                            <thead class="bg-light">
                                <tr>
                                    <th class="border-0 rounded-start">Course / Batch</th>
                                    <th class="border-0">Month</th>
                                    <th class="border-0">Amount</th>
                                    <th class="border-0">Date Paid</th>
                                    <th class="border-0 rounded-end">Status</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("StudentBatchPaymentOffCanvas", "StudentBatchPayment", new { area = "StudentPortal" })

@section Scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.30.1/moment.min.js"></script>

    <script src="~/js/student-portal/StudentBatchPayment-functions.js"></script>

    <script>
        let paymentTable;

        $(document).ready(function() {
            loadPaymentTable();
            loadSummary();
        });

        function loadPaymentTable() {
            paymentTable = $('#paymentTable').DataTable({
                "processing": true,
                "serverSide": true,
                "responsive": true,
                "ajax": {
                    "url": "@Url.Action("SearchPayments", "StudentBatchPayment")",
                    "type": "POST"
                },
                "language": {
                    "processing": `<div class="d-flex justify-content-center"><div class="spinner-border" style="color: var(--sensei-red);" role="status"><span class="visually-hidden">Loading...</span></div></div>`
                },
                "columns": [
                    { 
                        "data": null,
                        title: "Course / Batch",
                        "render": function(data) {
                            return `<div class="d-flex align-items-center">
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; color: var(--sensei-red);">
                                            <i data-feather="book"></i>
                                        </div>
                                        <div>
                                            <span class="fw-800 text-dark d-block mb-1" style="font-size: 0.9rem;">${data.studentBatch.batch.course.courseName}</span>
                                            <span class="badge bg-light text-dark border fw-600">${data.studentBatch.batch.batchName}</span>
                                        </div>
                                    </div>`;
                        }
                    },
                    { 
                        "data": "PaymentMonth",
                        "render": function(data) {
                            return `<div class="d-flex align-items-center">
                                        <i data-feather="calendar" class="me-2 text-muted" style="width: 14px; height: 14px;"></i>
                                        <span class="fw-700 text-dark">${moment(data).format('MMMM YYYY')}</span>
                                    </div>`;
                        }
                    },
                    { 
                        "data": null,
                        "render": function(data) {
                            return `<div class="fw-800" style="color: var(--sensei-red); font-size: 0.95rem;">Rs. ${parseFloat(data.amount).toLocaleString(undefined, {minimumFractionDigits: 2})}</div>`;
                        }
                    },
                    { 
                        "data": "PaymentDate",
                        "render": function(data) {
                            return `<div class="text-muted fw-600 small">
                                        <i data-feather="clock" class="me-1" style="width: 12px; height: 12px;"></i>
                                        ${moment(data).format('MMM DD, YYYY')}
                                    </div>`;
                        }
                    },
                    { 
                        "data": "IsApproved",
                        "render": function(data) {
                            return data ? 
                                '<div class="d-inline-flex align-items-center badge rounded-pill fw-800 p-2 px-3" style="background: rgba(40, 167, 69, 0.1); color: #28a745;"><i data-feather="check-circle" class="me-1" style="width: 14px; height: 14px;"></i> Verified</div>' : 
                                '<div class="d-inline-flex align-items-center badge rounded-pill fw-800 p-2 px-3" style="background: rgba(255, 193, 7, 0.1); color: #B08D00;"><i data-feather="clock" class="me-1" style="width: 14px; height: 14px;"></i> Pending</div>';
                        }
                    }
                ],
                "drawCallback": function() {
                    if (window.feather) { feather.replace(); }
                }
            });
        }

        function loadSummary() {
            $.get("@Url.Action("GetPaymentSummary", "StudentBatchPayment")", function(data) {
                let html = '';
                if (data && data.length > 0) {
                    data.forEach(item => {
                        html += `
                            <div class="col-md-6 col-xl-4 mb-4">
                                <div class="card h-100 shadow-sm hover-elevate border-0 rounded-4 overflow-hidden position-relative" style="transition: transform 0.2s, boxShadow 0.2s;">
                                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(216, 50, 54, 0.03) 0%, rgba(216, 50, 54, 0) 100%); pointer-events: none;"></div>
                                    <div class="card-body p-4 position-relative z-1">
                                        <div class="d-flex justify-content-between align-items-start mb-4">
                                            <div>
                                                <div class="text-uppercase text-muted fw-bold small mb-1" style="letter-spacing: 0.05em; font-size: 0.75rem;">${item.courseName}</div>
                                                <h4 class="fw-900 mb-0 text-dark" style="font-size: 1.15rem;">${item.batchName}</h4>
                                            </div>
                                            <div class="flex-shrink-0 ms-3">
                                                <div class="d-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 48px; height: 48px; color: var(--sensei-red);">
                                                    <i data-feather="book-open" style="width: 20px; height: 20px;"></i>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="pt-3 border-top" style="border-color: rgba(0,0,0,0.05) !important;">
                                            <div class="row g-0 align-items-center mb-3">
                                                <div class="col">
                                                    <div class="text-muted small fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Total Submitted</div>
                                                    <div class="fw-800 text-dark">Rs. ${parseFloat(item.totalPaid).toLocaleString(undefined, {minimumFractionDigits: 2})}</div>
                                                </div>
                                                <div class="col-auto">
                                                    <i data-feather="arrow-up-right" class="text-muted opacity-50"></i>
                                                </div>
                                            </div>
                                            <div class="row g-0 align-items-center bg-light rounded-3 p-3">
                                                <div class="col">
                                                    <div class="text-success small fw-bold text-uppercase mb-1" style="font-size: 0.7rem;">Total Verified</div>
                                                    <div class="fw-900 text-success mb-0" style="font-size: 1.1rem;">Rs. ${parseFloat(item.totalApproved).toLocaleString(undefined, {minimumFractionDigits: 2})}</div>
                                                </div>
                                                <div class="col-auto">
                                                    <div class="d-flex align-items-center justify-content-center bg-success rounded-circle bg-opacity-10 text-success" style="width: 32px; height: 32px;">
                                                        <i data-feather="check" style="width: 16px; height: 16px;"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                } else {
                    html = `
                        <div class="col-12">
                            <div class="alert alert-light border-0 shadow-sm d-flex align-items-center p-4 rounded-4" role="alert">
                                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm me-4 flex-shrink-0" style="width: 48px; height: 48px; color: var(--sensei-red);">
                                    <i data-feather="info"></i>
                                </div>
                                <div>
                                    <h6 class="alert-heading fw-800 mb-1 text-dark">No Payment Summaries Found</h6>
                                    <p class="mb-0 text-muted small">You don't have any payment history yet. New payments will appear here.</p>
                                </div>
                            </div>
                        </div>
                    `;
                }
                $('#summaryContainer').html(html);
                if (window.feather) { feather.replace(); }
            });
        }

    </script>
}
