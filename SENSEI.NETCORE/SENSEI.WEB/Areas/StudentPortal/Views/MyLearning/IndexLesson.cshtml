@{
    ViewData["Title"] = "My Learning";
    var lessonEncryptedKey = ViewBag.EncryptedKey;
    var lessonName = ViewBag.LessonName;
}

<style>
    :root {
        --learning-primary: #D83236;
    }

    .section-header {
        padding: 2rem 0;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        margin-bottom: 3rem;
    }

    .section-title {
        font-family: 'Noto Serif JP', serif;
        font-weight: 900;
        font-size: 2rem;
        color: #1e293b;
        margin-bottom: 0.5rem;
        position: relative;
        display: inline-block;
    }

    .section-title::after {
        content: "";
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 40px;
        height: 3px;
        background: var(--learning-primary);
        border-radius: 2px;
    }

    .sakura-bg {
        background-color: #fffcfc;
        background-image: radial-gradient(#ffeef1 1px, transparent 1px);
        background-size: 40px 40px;
        min-height: 100vh;
        padding-top: 1rem;
        padding-bottom: 3rem;
    }

    .lesson-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        background: #fff;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        height: 100%;
    }
</style>

<div class="container-fluid p-0 sakura-bg">

    <!-- Restored Clean Header -->
    <div class="row mb-4">
        <div class="col-12 col-xl-11 mx-auto">
            <div class="section-header">
                <h1 class="section-title">@lessonName</h1>
                <p class="text-muted fw-600">Pick up where you left off and master Japanese step by step. 🌸</p>
            </div>
        </div>
    </div>

    <!-- Lesson Cards Grid -->
    <div class="row" id="lessonSummary">
    </div>



</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Re-initialize feather icons if any were added dynamically (though here they are static)
            if (window.feather) {
                feather.replace();
            }
        });

        $(document).ready(function() {
           loadLessons();
        });

        function loadLessons(start = 0, length = 10, searchValue = "") {
            $.ajax({
                url: "@Url.Action("LessonSummaryView", "MyLearning")",
                type: "GET",
                dataType: "html",
                data: {
                    start: start,
                    length: length,
                    searchValue: searchValue,
                    lessonEncryptedKey: '@lessonEncryptedKey'
                },
                success: function (data) {

                    $("#lessonSummary").html(data);

                    if (window.feather) feather.replace();
                },
                error: function (xhr) {
                    console.error("Failed to load lessons", xhr);
                }
            });
        }

    </script>
}
