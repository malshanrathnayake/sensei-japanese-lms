@{
    Layout = null;
}

<div class="offcanvas-header bg-light border-bottom">
    <h5 class="offcanvas-title fw-800 text-primary">
        <i class="fas fa-clock me-2"></i>Request Temporary Access
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
</div>

<div class="offcanvas-body">
    <div class="alert alert-soft-primary small mb-4" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        Choose how long you need access to this lesson. Your request will be sent to the administrator for approval.
    </div>

    <form id="LessonRequestAccessForm" asp-area="StudentPortal" asp-controller="MyLearning" asp-action="LessonRequestAccess"
          data-ajax="true" data-ajax-method="POST"
          data-ajax-begin="onRequestAccessBegin" data-ajax-success="onRequestAccessSuccess" data-ajax-failure="onRequestAccessFailure">

        <input type="hidden" name="q" value="@ViewBag.EncryptedKey" />

        <div class="mb-4">
            <label class="form-label fw-bold text-dark mb-3">Select Duration</label>
            
            <div class="d-grid gap-3">
                <div class="form-check custom-option border rounded-3 p-3 transition-all hover-shadow">
                    <input class="form-check-input" type="radio" name="duration" id="duration1d" value="1d" checked>
                    <label class="form-check-label w-100 cursor-pointer" for="duration1d">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="d-block fw-800">1 Day Extension</span>
                                <small class="text-muted">Perfect for a quick review session</small>
                            </div>
                            <i class="fas fa-bolt text-warning"></i>
                        </div>
                    </label>
                </div>

                <div class="form-check custom-option border rounded-3 p-3 transition-all hover-shadow">
                    <input class="form-check-input" type="radio" name="duration" id="duration3d" value="3d">
                    <label class="form-check-label w-100 cursor-pointer" for="duration3d">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="d-block fw-800">3 Days Extension</span>
                                <small class="text-muted">Enough time to master the content</small>
                            </div>
                            <i class="fas fa-calendar-day text-primary"></i>
                        </div>
                    </label>
                </div>

                <div class="form-check custom-option border rounded-3 p-3 transition-all hover-shadow">
                    <input class="form-check-input" type="radio" name="duration" id="duration7d" value="7d">
                    <label class="form-check-label w-100 cursor-pointer" for="duration7d">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="d-block fw-800">1 Week Extension</span>
                                <small class="text-muted">Full access for deep study</small>
                            </div>
                            <i class="fas fa-calendar-week text-success"></i>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-5">
            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="offcanvas">
                Cancel
            </button>
            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-800 shadow-sm" style="background: var(--sensei-red); border: none;">
                Submit Request <i class="fas fa-paper-plane ms-1"></i>
            </button>
        </div>
    </form>
</div>

<style>
    .custom-option {
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .custom-option:hover {
        background-color: #f8fafc;
        border-color: var(--sensei-red) !important;
        transform: translateY(-2px);
    }
    .form-check-input:checked + .form-check-label .fw-800 {
        color: var(--sensei-red);
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>
