@using SENSEI.DOMAIN
@using core_web.Helpers
@model BatchLesson

@{
    ViewData["Title"] = $"Lesson {Model?.Lesson?.LessonName}";
    
    // Improved Video ID Extraction
    string videoId = "";
    if (!string.IsNullOrEmpty(Model.RecordingUrl))
    {
        if (Model.RecordingUrl.Contains("v="))
        {
            videoId = Model.RecordingUrl.Split("v=").LastOrDefault()?.Split('&').FirstOrDefault();
        }
        else if (Model.RecordingUrl.Contains("youtu.be/"))
        {
            videoId = Model.RecordingUrl.Split("youtu.be/").LastOrDefault()?.Split('?').FirstOrDefault();
        }
    }
    var studentId = Convert.ToInt64(Context.Session.GetString("StudentId") ?? "0");

    // Check for temporary access
    var myAccess = Model.BatchStudentLessonAccesses?.FirstOrDefault(e => e.StudentId == studentId);
    var latestApprovedRequest = myAccess?.BatchStudentLessonAccessRequests?
        .Where(r => r.ApproveStatusEnum == ApproveStatusEnum.Approved && r.RequestEndDate > DateTime.Now)
                .OrderByDescending(r => r.RequestEndDate)
                .FirstOrDefault();
    var hasTemporaryAccess = latestApprovedRequest != null;
}

<style>
    body {
        user-select: none;
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
    }

    .player-container {
        position: relative;
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        background: #000;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    .player-wrapper {
        position: relative;
        width: 100%;
        padding-top: 56.25%; /* 16:9 Aspect Ratio */
    }

    #player {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
        filter: none !important; /* Ensure no ash color/filter effect */
    }

    /* Blockers to prevent interaction with specific YT UI elements */
    .yt-title-blocker {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 25%; /* Covers top 25% of the player */
        z-index: 110;
        background: rgba(0,0,0,0.01); /* Hit-test layer */
        pointer-events: all; /* Catch all clicks */
        cursor: default;
    }

    .yt-logo-blocker {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 40%; /* Expanded coverage for YouTube logo */
        height: 80px; /* Taller to cover bar icons */
        z-index: 110;
        background: rgba(0,0,0,0.01); /* Hit-test layer */
        pointer-events: all;
        cursor: default;
    }

    /* New comprehensive bottom bar blocker */
    .yt-bottom-blocker {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 50px; /* Covers the bottom control bar specifically */
        z-index: 110;
        background: rgba(0,0,0,0.01); /* Invisible hit-test layer */
        pointer-events: all;
        cursor: default;
    }

    /* Cinema Mode */
    .cinema-mode-active #videoColumn {
        width: 100%;
        max-width: 100%;
        flex: 0 0 100%;
    }

    .cinema-mode-active #referenceColumn {
        display: none;
    }

    #btnEnlarge {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 50px;
        padding: 5px 15px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    #btnEnlarge:hover {
        background: var(--bs-primary);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(216, 50, 54, 0.2);
    }

    #btnEnlarge.active {
        background: #D83236;
        color: white;
        border-color: #D83236;
    }

    /* Target the container in fullscreen */
    #playerContainer:fullscreen {
        border-radius: 0;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #playerContainer:-webkit-full-screen {
        border-radius: 0;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .player-container.is-paused #player {
        filter: none;
    }
</style>

<div class="container-fluid p-0">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">@Model?.Lesson?.LessonName</h1>

        @if (Model.StudentBatchLessonViews.Where(e => e.BatchLessonId == Model.BatchLessonId && e.StudentId == studentId && e.IsCompleted).Any())
        {
            <button type="button" class="btn btn-primary" disabled>
                Completed
            </button>
        }
        else
        {
            <button type="button" class="btn btn-primary" id="btnComplete" data-action-url="/StudentPortal/MyLearning/MarkBatchLessonComplete?q=@Model.EncryptedKey">
                Mark as Complete
            </button>
        }

    </div>

    <div class="row" id="playerMainRow">
        <div class="col-lg-8 col-md-12 col-sm-12" id="videoColumn">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center bg-white py-3">
                    <h5 class="card-title mb-0 fw-800" style="color: #334155;">@Model.Lesson.LessonName</h5>
                    <button class="btn btn-sm btn-outline-primary" id="btnEnlarge" title="Full Screen View">
                        <i data-feather="maximize" id="enlargeIcon"></i> <span>Expand Player</span>
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="player-container" id="playerContainer">
                        <div class="player-wrapper">
                            <div id="player"></div>
                            <!-- Title blocker (hides share and other top bar items) -->
                            <div class="yt-title-blocker" oncontextmenu="return false;"></div>
                            <!-- Logo blocker (hides bottom right Watch on YT link) -->
                            <div class="yt-logo-blocker" oncontextmenu="return false;"></div>
                            <!-- NEW: Bottom bar blocker (hides share, more videos etc) -->
                            <div class="yt-bottom-blocker" oncontextmenu="return false;"></div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="bg-soft-danger text-danger p-2 rounded-3">
                            <i data-feather="calendar" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div class="flex-fill">
                            <span class="text-muted small d-block fw-bold text-uppercase" style="letter-spacing: 0.5px;">Added Date</span>
                            <span class="fw-800" style="color: #1e293b;">@Model.LessonDateTime.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <div class="flex-fill">
                            <span class="text-muted small d-block fw-bold text-uppercase" style="letter-spacing: 0.5px;">Expiry Date</span>
                            <span class="fw-800 text-danger" style="color: #D83236;">@Model.RecordingExpireDate.ToString("MMMM dd, yyyy")</span>

                            @if (hasTemporaryAccess)
                            {
                                var timeLeft = latestApprovedRequest.RequestEndDate - DateTime.Now;
                                var timeText = timeLeft.TotalDays >= 1 
                                    ? $"Ends in {Math.Ceiling(timeLeft.TotalDays)} Days" 
                                    : $"Ends in {Math.Ceiling(timeLeft.TotalHours)} Hours";
                                    
                                <div class="mt-1">
                                    <span class="badge bg-soft-warning text-dark rounded-pill fw-900" style="font-size: 0.65rem; letter-spacing: 0.05em; border: 1px solid #ffc107;">
                                        <i class="align-middle me-1" data-feather="clock" style="width: 10px;"></i> @timeText.ToUpper()
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="fw-800 text-uppercase small text-muted mb-3" style="letter-spacing: 0.5px;">Recording Description</h6>
                            <p class="mb-0 text-secondary" style="line-height: 1.6; font-size: 1rem; white-space: pre-line;">
                                @Model.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-12 col-sm-12" id="referenceColumn">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Lesson References</h5>
                </div>
                <div class="card-body">

                    @if (Model.BatchLessonReferences != null && Model.BatchLessonReferences.Any(r => !r.IsDeleted))
                    {
                        <div class="accordion" id="lessonRefsAccordion">
                            @{
                                var refs = Model.BatchLessonReferences.Where(r => !r.IsDeleted).ToList();

                                @for (int i = 0; i < refs.Count; i++)
                                {
                                    var r = refs[i];
                                    var headingId = $"refHeading{i}";
                                    var collapseId = $"refCollapse{i}";
                                    var isFirst = i == 0;
                                    var viewerUrl = r.ReferenceUrl
                                        .Replace("/view?usp=sharing", "/preview")
                                        .Replace("/view", "/preview");

                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="@headingId">
                                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#@collapseId"
                                                    aria-expanded="@(isFirst ? "true" : "false")"
                                                    aria-controls="@collapseId">
                                                @(string.IsNullOrWhiteSpace(r.Description) ? $"Reference {i + 1}" : r.Description)
                                            </button>
                                        </h2>

                                        <div id="@collapseId"
                                             class="accordion-collapse collapse @(isFirst ? "show" : "")"
                                             aria-labelledby="@headingId"
                                             data-bs-parent="#lessonRefsAccordion">
                                            <div class="accordion-body">
                                                <div class="ratio ratio-16x9">
                                                    <iframe src="@viewerUrl" allowfullscreen></iframe>
                                                </div>

                                                <div class="mt-2 d-flex gap-2">
                                                    <a class="btn btn-sm btn-outline-primary" href="@r.ReferenceUrl" target="_blank" rel="noopener">
                                                        Open in new tab
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No references added for this lesson.</div>
                    }

                </div>
            </div>
        </div>
    </div>

</div>

@Html.RenderAction("MyLearningOffCanvas", "MyLearning", new { area = "StudentPortal" })

@section Scripts {
    <script>
        // Global Right Click Block for Lesson Page
        document.addEventListener('contextmenu', event => event.preventDefault());
    </script>
    <script src="~/js/student-portal/my-learning-functions.js"></script>

    <script>

        var tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        var firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);


        var player;

        function onYouTubeIframeAPIReady() {
            player = new YT.Player('player', {
                width: '100%',
                videoId: '@videoId',
                playerVars: {
                    'controls': 1,           // Show native controls
                    'modestbranding': 1,      // Minimal YT logo
                    'rel': 0,                // No related videos from other channels
                    'showinfo': 0,           // Hide video title/info
                    'fs': 0,                 // Disable native fullscreen to force secure expansion
                    'iv_load_policy': 3,     // Hide annotations
                    'autohide': 1,           // Auto-hide controls
                    'disablekb': 1,          // Disable keyboard shortcuts to prevent 'G' or 'watch on YT'
                    'cc_load_policy': 0,     // Disable captions by default
                    'origin': window.location.origin
                },
                events: {
                    'onReady': onPlayerReady,
                    'onStateChange': onPlayerStateChange
                }
            });
        }


        function onPlayerReady(event) {
            // event.target.playVideo(); // Auto-play is often blocked by browsers
        }


        function onPlayerStateChange(event) {
            var container = document.getElementById('playerContainer');
            
            if (event.data == YT.PlayerState.ENDED) {
                // Instant Wipe: Hide player to block 'More Videos'
                document.getElementById('player').style.display = 'none';
            } else {
                document.getElementById('player').style.display = 'block';
            }
        }

        // Block 'Tab' key to prevent keyboard navigation to hidden YT links
        $('#playerContainer').on('keydown', function(e) {
            if (e.keyCode === 9) { // Tab key
                e.preventDefault();
                return false;
            }
        });

        // Block right click on entire player container to prevent copying links
        $('#playerContainer').on('contextmenu', function(e) {
            e.preventDefault();
            return false;
        });

        // Prevent dragging of any player elements
        $('#playerContainer').on('mousedown', function(e) {
            if(e.button === 2) return false; // Right click
        });

        $(document).ready(function () {
            $('#btnEnlarge').click(function () {
                var container = document.getElementById('playerContainer');
                
                if (!document.fullscreenElement && !document.webkitFullscreenElement) {
                    // Enter Fullscreen
                    if (container.requestFullscreen) {
                        container.requestFullscreen();
                    } else if (container.webkitRequestFullscreen) {
                        container.webkitRequestFullscreen();
                    } else if (container.msRequestFullscreen) {
                        container.msRequestFullscreen();
                    }
                } else {
                    // Exit Fullscreen
                    if (document.exitFullscreen) {
                        document.exitFullscreen();
                    } else if (document.webkitExitFullscreen) {
                        document.webkitExitFullscreen();
                    } else if (document.msExitFullscreen) {
                        document.msExitFullscreen();
                    }
                }
            });

            // Sync button UI with fullscreen state
            document.addEventListener('fullscreenchange', handleFullscreenChange);
            document.addEventListener('webkitfullscreenchange', handleFullscreenChange);

            function handleFullscreenChange() {
                var isFS = document.fullscreenElement || document.webkitFullscreenElement;
                if (isFS) {
                    $('#enlargeIcon').attr('data-feather', 'minimize');
                    $('#btnEnlarge').html('<i data-feather="minimize"></i> Shrink').addClass('active');
                } else {
                    $('#enlargeIcon').attr('data-feather', 'maximize');
                    $('#btnEnlarge').html('<i data-feather="maximize"></i> Enlarge').removeClass('active');
                }
                if (window.feather) feather.replace();
            }

            // $('#btnComplete').click(function () {
            //     var url = $(this).data('action-url');
            //     $.post(url, function (response) {
            //         if (response.success) {
            //             popUpNotification('success', response.message);
            //             setTimeout(function(){ location.reload(); }, 1500);
            //         } else {
            //             popUpNotification('error', response.message);
            //         }
            //     }).fail(function () {
            //         popUpNotification('error', 'An error occurred while marking the lesson as complete.');
            //     });
            // });
        });

    </script>

}