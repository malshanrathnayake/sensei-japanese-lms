@using SENSEI.DOMAIN
@model IEnumerable<BatchLesson>
@{
    Layout = null;
    var studentIdStr = Context.Session.GetString("StudentId") ?? "0";
    long studentId = Convert.ToInt64(studentIdStr);
}

@{
    if(Model != null && Model.Any())
    {
        foreach(var batchLesson in Model)
        {

            if (batchLesson.BatchStudentLessonAccesses.Any(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId && e.HasAccess))
            {
                <div class="col-12 col-md-6 col-xl-4 mb-4">
                    <div class="card lesson-card">
                        <div class="lesson-image-wrapper" style="height: 180px; position: relative; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                            <img src="~/theme/v1/img/photos/unsplash-1.jpg" alt="@batchLesson.Description" class="lesson-image" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.6;">
                            <span class="lesson-badge" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.5); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; backdrop-filter: blur(4px);">@batchLesson.Lesson.LessonName</span>
                        </div>
                        <div class="lesson-content" style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="lesson-title" style="font-size: 1.1rem; font-weight: 800; margin-bottom: 0; color: #334155;">@batchLesson.Description</h3>
                                <span class="badge @(batchLesson.StudentBatchLessonViews.Any(e => e.IsCompleted) ? "bg-success" : "bg-outline-primary") rounded-pill" style="font-size: 0.7rem;">
                                    @(batchLesson.StudentBatchLessonViews.Any(e => e.IsCompleted) ? "Completed" : "In Progress")
                                </span>
                            </div>
                            
                            <div class="lesson-footer mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="text-muted small"><i class="align-middle me-1" data-feather="clock" style="width: 14px;"></i> Available Now</span>
                                <a href="@Url.Action("LessonDetail", "MyLearning", new { q = batchLesson.EncryptedKey })" class="btn btn-primary btn-sm rounded-pill px-4 py-2" style="font-weight: 700; background: #D83236; border: none; box-shadow: 0 4px 12px rgba(216, 50, 54, 0.2);">
                                    Study <i class="align-middle ms-1" data-feather="arrow-right" style="width: 14px;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-12 col-md-6 col-xl-4 mb-4" style="opacity:0.7;">
                    <div class="card lesson-card" style="filter: grayscale(80%);">
                        <div class="lesson-image-wrapper" style="height: 180px; position: relative; background: #f8f9fa;">
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i data-feather="lock" style="width: 48px; height: 48px; color: #cbd5e1;"></i>
                            </div>
                            <span class="lesson-badge" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.5); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700; backdrop-filter: blur(4px);">@batchLesson.Lesson.LessonName</span>
                        </div>
                        <div class="lesson-content" style="padding: 1.5rem;">
                            <h3 class="lesson-title" style="font-size: 1.1rem; font-weight: 800; color: #94a3b8;">@batchLesson.Description</h3>
                            <div class="lesson-footer mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-soft-secondary text-secondary rounded-pill" style="font-size: 0.7rem;">Payment Required</span>
                                <button class="btn btn-secondary btn-sm disabled rounded-pill px-4 py-2" style="font-weight: 700;">
                                    Locked <i class="align-middle ms-1" data-feather="lock" style="width: 14px;"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            
        }
    }
}