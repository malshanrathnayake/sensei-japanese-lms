@using SENSEI.DOMAIN
@model IEnumerable<BatchLesson>
@{
    Layout = null;
    var studentIdStr = Context.Session.GetString("StudentId") ?? "0";
    long studentId = Convert.ToInt64(studentIdStr);
}

@{
    if(Model != null && Model.Any())
    {
        foreach(var batchLesson in Model.OrderBy(e => e.BatchLessonId))
        {
            var courseName = (batchLesson.Lesson?.Course?.CourseName ?? "").ToUpper();
            var courseCode = (batchLesson.Lesson?.Course?.CourseCode ?? "").ToUpper();
            var batchName = (batchLesson.Batch?.BatchName ?? "").ToUpper();
            var firstLessonName = (batchLesson.Lesson?.LessonName ?? "").ToUpper();
            var currentUnitName = (batchLesson.Description ?? "").ToUpper();
            
            string coverImage = "/theme/v1/img/photos/study_cover.png"; // New educational default
            
            // Priority matching (checking Course, Code, Batch, Lesson, and Unit Description)
            if (courseName.Contains("N5") || courseCode.Contains("N5") || batchName.Contains("N5") || firstLessonName.Contains("N5") || firstLessonName.Contains("KANJI") || currentUnitName.Contains("N5")) 
                coverImage = "/theme/v1/img/photos/n5_cover.png";
            else if (courseName.Contains("N4") || courseCode.Contains("N4") || batchName.Contains("N4") || firstLessonName.Contains("N4") || currentUnitName.Contains("N4")) 
                coverImage = "/theme/v1/img/photos/n4_cover.png";
            else if (courseName.Contains("SSW") || courseCode.Contains("SSW") || batchName.Contains("SSW") || firstLessonName.Contains("SSW") || currentUnitName.Contains("SSW")) 
                coverImage = "/theme/v1/img/photos/ssw_cover.png";
            else if (courseName.Contains("AL") || courseCode.Contains("AL") || batchName.Contains("AL") || firstLessonName.Contains("AL") || currentUnitName.Contains("AL")) 
                coverImage = "/theme/v1/img/photos/al_cover.png";
            else if (firstLessonName.Contains("WRAPUP") || firstLessonName.Contains("SESSION") || currentUnitName.Contains("WRAPUP") || currentUnitName.Contains("SESSION"))
                coverImage = "/theme/v1/img/photos/japanese_cover.png"; // Use the 'sunset' one for sessions

            var hasPaidAccess = batchLesson.BatchStudentLessonAccesses.Any(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId && e.HasAccess);
            var isFirstWeekTrial = batchLesson.Batch != null && batchLesson.LessonDateTime <= batchLesson.Batch.BatchStartDate.AddDays(7);

            if (hasPaidAccess || isFirstWeekTrial)
            {
                <div class="col-12 col-md-6 col-xl-4 mb-4">
                    <div class="card lesson-card h-100 shadow-sm border-0">
                        <div class="lesson-image-wrapper" style="height: 180px; position: relative; background: url('@coverImage') center/cover no-repeat;">
                            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.1) 100%);"></div>
                            <span class="lesson-badge" style="position: absolute; top: 15px; right: 15px; background: rgba(216, 50, 54, 0.9); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; backdrop-filter: blur(4px); box-shadow: 0 4px 10px rgba(0,0,0,0.2);">@batchLesson.Lesson.LessonName</span>
                        </div>
                        <div class="lesson-content" style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h3 class="lesson-title" style="font-size: 1.15rem; font-weight: 800; margin-bottom: 0; color: #1e293b; line-height:1.4;">@batchLesson.Description</h3>
                            </div>
                            
                            <div class="d-flex align-items-center mb-4">
                                @if(batchLesson.StudentBatchLessonViews.Any(e => e.IsCompleted)) {
                                    <span class="badge bg-success rounded-pill px-3 py-1" style="font-size: 0.7rem; font-weight:700;">Completed</span>
                                } else {
                                    <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-1" style="font-size: 0.7rem; font-weight:700;">In Progress</span>
                                }
                            </div>

                            <div class="d-flex align-items-center mb-4">

                                @{
                                    var overallRating = batchLesson.BatchStudentLessonAccesses.Average(e => e.Rating);
                                    overallRating = (int)Math.Round(overallRating ?? 0);

                                    if (overallRating.HasValue)
                                    {
                                        <div class="d-inline-flex align-items-center gap-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= overallRating.Value)
                                                {
                                                    <span style="color:#f5b301; font-size:18px;">&#9733;</span>
                                                }
                                                else
                                                {
                                                    <span style="color:#d6d6d6; font-size:18px;">&#9733;</span>
                                                }
                                            }
                                            <span class="ms-1 text-muted">(@overallRating/5)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>No Yet Rated</span>
                                    }
                                }
                                
                            </div>
                            
                            <div class="lesson-footer mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-600"><i class="align-middle me-1 text-danger" data-feather="video" style="width: 14px;"></i> Video Lesson & Expire on @batchLesson.RecordingExpireDate.ToString("yyyy-MMM-dd")</span>
                                <a href="@Url.Action("LessonDetail", "MyLearning", new { q = batchLesson.EncryptedKey })" class="btn btn-primary btn-sm rounded-pill px-4 py-2" style="font-weight: 800; background: #D83236; border: none; box-shadow: 0 8px 20px rgba(216, 50, 54, 0.25); transition: all 0.3s ease;">
                                    Study <i class="align-middle ms-1" data-feather="play" style="width: 14px;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
            //lesson expired && (lesson has not access OR Lesson not in access list)
            else if ((batchLesson.RecordingExpireDate < DateTime.Now) && ((batchLesson.BatchStudentLessonAccesses.Any(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId && !e.HasAccess) || (!batchLesson.BatchStudentLessonAccesses.Any(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId)))))
            {
                <div class="col-12 col-md-6 col-xl-4 mb-4">
                    <div class="card lesson-card h-100 shadow-sm border-0">
                        <div class="lesson-image-wrapper" style="height: 180px; position: relative; background: url('@coverImage') center/cover no-repeat;">
                            <div class="d-flex align-items-center justify-content-center h-100" style="background: rgba(0,0,0,0.2);">
                                <div class="bg-white rounded-circle p-3 shadow-lg">
                                    <i data-feather="lock" style="width: 32px; height: 32px; color: #D83236;"></i>
                                </div>
                            </div>
                            <span class="lesson-badge" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.6); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700;">@batchLesson.Lesson.LessonName</span>
                        </div>
                        <div class="lesson-content" style="padding: 1.5rem;">
                            <h3 class="lesson-title" style="font-size: 1.15rem; font-weight: 800; color: #64748b; line-height:1.4;">@batchLesson.Description</h3>

                            <div class="d-flex align-items-center mb-4">

                                @{
                                    var overallRating = batchLesson.BatchStudentLessonAccesses.Average(e => e.Rating);
                                    overallRating = (int)Math.Round(overallRating ?? 0);

                                    if (overallRating.HasValue)
                                    {
                                        <div class="d-inline-flex align-items-center gap-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= overallRating.Value)
                                                {
                                                    <span style="color:#f5b301; font-size:18px;">&#9733;</span>
                                                }
                                                else
                                                {
                                                    <span style="color:#d6d6d6; font-size:18px;">&#9733;</span>
                                                }
                                            }
                                            <span class="ms-1 text-muted">(@overallRating/5)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>No Yet Rated</span>
                                    }
                                }

                            </div>

                            <div class="lesson-footer mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-soft-secondary text-secondary rounded-pill fw-700" style="font-size: 0.7rem;">Lesson Expired : @batchLesson.RecordingExpireDate.ToString("yyyy-MMM-dd")</span>

                                @{
                                    var batchLessonAccessId = batchLesson.BatchStudentLessonAccesses.FirstOrDefault(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId)?.BatchStudentLessonAccessId;
                                    var batchLessonAccessEncryptedId = batchLesson.BatchStudentLessonAccesses.FirstOrDefault(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId)?.EncryptedKey;
                                }


                                @if (batchLesson.BatchStudentLessonAccesses.FirstOrDefault(e => e.StudentId == studentId && e.BatchLessonId == batchLesson.BatchLessonId).BatchStudentLessonAccessRequests.Any(e => e.BatchStudentLessonAccessId == batchLessonAccessId))
                                {
                                    <button class="btn btn-secondary btn-sm disabled rounded-pill px-4 py-2" style="font-weight: 800;">
                                        Access Pending <i class="align-middle ms-1" data-feather="clock" style="width: 14px;"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-secondary btn-sm rounded-pill px-4 py-2 request-access" style="font-weight: 800;" data-action-url="@Url.Action("LessonRequestAccess", "MyLearning", new { q = batchLessonAccessEncryptedId })">
                                        Request Access <i class="align-middle ms-1" data-feather="arrow-right" style="width: 14px;"></i>
                                    </button>
                                }
                                
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-12 col-md-6 col-xl-4 mb-4" style="opacity:0.8;">
                    <div class="card lesson-card h-100 shadow-sm border-0" style="filter: grayscale(100%);">
                        <div class="lesson-image-wrapper" style="height: 180px; position: relative; background: url('@coverImage') center/cover no-repeat;">
                            <div class="d-flex align-items-center justify-content-center h-100" style="background: rgba(0,0,0,0.2);">
                                <div class="bg-white rounded-circle p-3 shadow-lg">
                                    <i data-feather="lock" style="width: 32px; height: 32px; color: #D83236;"></i>
                                </div>
                            </div>
                            <span class="lesson-badge" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.6); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 700;">@batchLesson.Lesson.LessonName</span>
                        </div>
                        <div class="lesson-content" style="padding: 1.5rem;">
                            <h3 class="lesson-title" style="font-size: 1.15rem; font-weight: 800; color: #64748b; line-height:1.4;">@batchLesson.Description</h3>

                            <div class="d-flex align-items-center mb-4">

                                @{
                                    var overallRating = batchLesson.BatchStudentLessonAccesses.Average(e => e.Rating);
                                    overallRating = (int)Math.Round(overallRating ?? 0);

                                    if (overallRating.HasValue)
                                    {
                                        <div class="d-inline-flex align-items-center gap-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= overallRating.Value)
                                                {
                                                    <span style="color:#f5b301; font-size:18px;">&#9733;</span>
                                                }
                                                else
                                                {
                                                    <span style="color:#d6d6d6; font-size:18px;">&#9733;</span>
                                                }
                                            }
                                            <span class="ms-1 text-muted">(@overallRating/5)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span>No Yet Rated</span>
                                    }
                                }

                            </div>

                            <div class="lesson-footer mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-soft-secondary text-secondary rounded-pill fw-700" style="font-size: 0.7rem;">Access Locked</span>
                                <button class="btn btn-secondary btn-sm disabled rounded-pill px-4 py-2" style="font-weight: 800; opacity: 0.5;">
                                    Settle Payment <i class="align-middle ms-1" data-feather="lock" style="width: 14px;"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
}
