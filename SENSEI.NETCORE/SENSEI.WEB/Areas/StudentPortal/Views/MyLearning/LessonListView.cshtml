@using SENSEI.DOMAIN
@model IEnumerable<BatchLesson>
@{
    Layout = null;
    var studentIdStr = Context.Session.GetString("StudentId") ?? "0";
    long studentId = Convert.ToInt64(studentIdStr);
}

@if (Model != null && Model.Any())
{
    foreach (var group in Model.GroupBy(e => e.LessonId))
    {
        var firstLesson = group.First();
        var totalUnits = group.Count();
        var completedUnits = group.SelectMany(e => e.StudentBatchLessonViews).Count(v => v.StudentId == studentId && v.IsCompleted);
        var progressPercent = totalUnits > 0 ? (completedUnits / (double)totalUnits) * 100 : 0;
        
        var lessonEncryptedKey = firstLesson.LessonEncryptedKey;

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card lesson-card h-100">
                <div class="lesson-image-wrapper">
                    <span class="lesson-badge">@firstLesson.Lesson.Course.CourseName</span>
                    <i data-feather="book-open" class="text-primary opacity-25" style="width: 80px; height: 80px;"></i>
                </div>
                <div class="lesson-content">
                    <h3 class="lesson-title">@firstLesson.Lesson.LessonName</h3>
                    
                    <div class="lesson-meta">
                        <span class="d-flex align-items-center"><i data-feather="layers" class="me-1" style="width: 14px;"></i> @totalUnits Sections</span>
                        <span class="d-flex align-items-center"><i data-feather="check-circle" class="me-1" style="width: 14px;"></i> @completedUnits Completed</span>
                    </div>

                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="progress-label">Course Progress</span>
                            <span class="fw-800 text-dark small">@Math.Round(progressPercent)%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width: @progressPercent%"
                                 aria-valuenow="@progressPercent"
                                 aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <a href="@Url.Action("IndexLesson", "MyLearning", new { q = lessonEncryptedKey, lessonName = firstLesson.Lesson.LessonName })" class="btn btn-continue">
                            <span>Continue Learning</span>
                            <i data-feather="arrow-right" style="width: 18px;"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="col-12">
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <div class="bg-soft-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i data-feather="book" style="width: 40px; height: 40px; color: var(--learning-primary);"></i>
            </div>
            <h4 class="fw-800 text-dark">No lessons found</h4>
            <p class="text-muted small mx-auto" style="max-width: 300px;">We couldn't find any lessons matching your current filters or search query.</p>
        </div>
    </div>
}