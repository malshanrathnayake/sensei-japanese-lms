@using SENSEI.DOMAIN
@model IEnumerable<BatchLesson>
@{
    Layout = null;
    var studentIdStr = Context.Session.GetString("StudentId") ?? "0";
    long studentId = Convert.ToInt64(studentIdStr);
}

@{
    if (Model != null && Model.Any())
    {
        foreach (var lesson in Model.GroupBy(e => e.LessonId))
        {
            var completedBatchLessons = lesson.First().StudentBatchLessonViews.Count(e => e.StudentId == studentId && e.LessonId == lesson.First().Lesson.LessonId && e.IsCompleted);
            var totalBatchLessons = (double)Model.Count(e => e.LessonId == lesson.First().Lesson.LessonId);

            var progressPercent = completedBatchLessons / totalBatchLessons * 100;

            var currentLessonName = lesson.Where(e => !e.StudentBatchLessonViews.Any(v => v.BatchLessonId == e.BatchLessonId))
                    .OrderBy(e => e.BatchLessonId)
                    .Select(e => e.Description)
                    .FirstOrDefault();

            var lessonEncryptedKey = lesson.First().LessonEncryptedKey;

            <div class="col-12 col-md-6 col-xl-4 mb-4">
                <div class="card lesson-card">
                    <div class="lesson-image-wrapper">
                        <span class="lesson-badge">@lesson.First().Lesson.Course.CourseName</span>
                    </div>
                    <div class="lesson-content">
                        <h3 class="lesson-title">@lesson.First().Lesson.LessonName</h3>
                        <div class="lesson-meta">
                            <span><i class="align-middle me-1" data-feather="book-open"></i>@Model.Count(e => e.LessonId == lesson.First().Lesson.LessonId)</span>
                        </div>
                        <p class="text-muted small">@lesson.First().Lesson.Description</p>
                        <div class="progress-wrapper">
                            <div class="d-flex justify-content-between mb-1 small text-muted">
                                <span>Progress</span>
                                <span>@progressPercent %</span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" role="progressbar" style="width: @progressPercent%"
                                     aria-valuenow="@progressPercent"
                                     aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <div class="lesson-footer">
                            <span class="text-primary fw-bold small">Current: @currentLessonName</span>
                            <a href="@Url.Action("IndexLesson", "MyLearning", new { q = lessonEncryptedKey })" class="btn btn-primary btn-continue">Go to Lesson <i class="align-middle ms-1" data-feather="arrow-right"></i></a>
                        </div>
                    </div>
                </div>
            </div>

        }
    }
}