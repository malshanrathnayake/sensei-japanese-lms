@using SENSEI.DOMAIN
@model IEnumerable<BatchLesson>
@{
    Layout = null;
    var studentIdStr = Context.Session.GetString("StudentId") ?? "0";
    long studentId = Convert.ToInt64(studentIdStr);
}

@{
    if (Model != null && Model.Any())
    {
        foreach (var lesson in Model.GroupBy(e => e.LessonId))
        {
            var completedBatchLessons = 0;
            foreach (var batchLesson in lesson)
            {
                completedBatchLessons += batchLesson.StudentBatchLessonViews.Count(e => e.StudentId == studentId && e.LessonId == lesson.First().Lesson.LessonId && e.IsCompleted);
            }

            var totalBatchLessons = (double)Model.Count(e => e.LessonId == lesson.First().Lesson.LessonId);

            var progressPercent = completedBatchLessons / totalBatchLessons * 100;
            progressPercent = Math.Round(progressPercent);

            var currentLessonName = lesson.Where(e => !e.StudentBatchLessonViews.Any(v => v.BatchLessonId == e.BatchLessonId))
                    .OrderBy(e => e.BatchLessonId)
                    .Select(e => e.Description)
                    .FirstOrDefault();

            var lessonEncryptedKey = lesson.First().LessonEncryptedKey;

            <div class="col-12 col-md-6 col-xl-4 mb-4">
                <div class="card lesson-card">
                    <div class="lesson-image-wrapper">
                        <span class="lesson-badge">@lesson.First().Lesson.Course.CourseName</span>
                        <div class="lesson-overlay-icon">
                             <i class="align-middle" data-feather="book-open" style="width: 48px; height: 48px; color: rgba(216,50,54,0.15);"></i>
                        </div>
                    </div>
                    <div class="lesson-content">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                             <h3 class="lesson-title mb-0">@lesson.First().Lesson.LessonName</h3>
                             <span class="badge @(progressPercent == 100 ? "bg-success" : "bg-soft-primary text-primary") rounded-pill px-3">@(progressPercent == 100 ? "Completed" : "Active")</span>
                        </div>
                        
                        <div class="lesson-meta mb-3">
                            <span title="Total Units"><i class="align-middle me-1" data-feather="layers"></i>@(lesson.Count()) Units</span>
                            <span title="Completed Units"><i class="align-middle me-1" data-feather="check-circle"></i>@completedBatchLessons Done</span>
                        </div>

                        <div class="progress-wrapper mb-4">
                            <div class="d-flex justify-content-between mb-2 small fw-bold">
                                <span class="text-muted">Mastery</span>
                                <span class="text-primary">@progressPercent%</span>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar" role="progressbar" style="width: @progressPercent%"
                                     aria-valuenow="@progressPercent"
                                     aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>

                        <div class="lesson-footer mt-auto pt-3 border-top d-flex align-items-center justify-content-between">
                            <div class="next-up">
                                <span class="d-block text-muted x-small text-uppercase fw-800" style="font-size: 0.6rem;">Next Up</span>
                                <span class="text-dark fw-bold small text-truncate d-inline-block" style="max-width: 150px;">@(currentLessonName ?? "All Done!")</span>
                            </div>
                            <a href="@Url.Action("IndexLesson", "MyLearning", new { q = lessonEncryptedKey })" class="btn btn-primary btn-sm rounded-pill px-4 py-2">
                                Continue <i class="align-middle ms-1" data-feather="chevron-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        }
    }
}