@{
	Layout = null;
	var userDisplayName = Context.Session.GetString("DisplayName") ?? "Student";
    var userEmail = Context.Session.GetString("UserName") ?? "";
	var userProfileImage = Context.Session.GetString("ProfileImage") ?? "/theme/v1/img/avatars/placeholder_1.jpeg";
}

<li class="nav-item dropdown px-lg-2">
	<a class="nav-link dropdown-toggle d-flex align-items-center py-0" href="#" id="studentProfileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
		<div class="position-relative d-inline-block me-2">
			<img src="@Url.Content(userProfileImage)" 
				 class="avatar img-fluid rounded-circle border border-2 border-white shadow-sm" 
				 alt="@userDisplayName" 
				 style="width: 40px; height: 40px; object-fit: cover; border-color: #fdeaea !important;" 
				 onerror="this.src='@Url.Content("/theme/v1/img/avatars/placeholder_1.jpeg")'" />
			<span class="position-absolute bottom-0 end-0 bg-success border border-2 border-white rounded-circle" style="width: 12px; height: 12px; transform: translate(5%, 5%);" title="Online"></span>
		</div>
		<div class="d-none d-lg-block text-start me-1">
			<div class="fw-800 text-dark lh-1 mb-1" style="font-size: 0.9rem; text-transform: capitalize;">@userDisplayName.ToLower()</div>
			<div class="text-muted fw-700" style="font-size: 0.7rem; letter-spacing: 0.01em;">Official Student</div>
		</div>
	</a>

	<div class="dropdown-menu dropdown-menu-end shadow-lg border-0 p-2 animated fadeIn" aria-labelledby="studentProfileDropdown" style="min-width: 260px; border-radius: 1.25rem; margin-top: 15px;">
		<!-- User Header -->
		<div class="dropdown-header d-flex flex-column align-items-center p-4 bg-light rounded-4 mb-2 mx-1">
			<div class="position-relative mb-3">
				<img src="@Url.Content(userProfileImage)" 
					 class="avatar img-fluid rounded-circle border border-4 border-white shadow-sm" 
					 style="width: 70px; height: 70px; object-fit: cover;"
					 onerror="this.src='@Url.Content("/theme/v1/img/avatars/placeholder_1.jpeg")'">
			</div>
			<h6 class="mb-1 fw-900 text-dark text-center text-capitalize">@userDisplayName.ToLower()</h6>
			<p class="text-muted small mb-0 fw-600 text-center" style="font-size: 0.75rem;">@userEmail</p>
		</div>

		<!-- Menu Actions -->
		<div class="p-1">
			<a class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-3 mb-1" href="@Url.Action("Index", "StudentProfile", new { area = "StudentPortal" })">
				<div class="d-flex align-items-center justify-content-center bg-soft-primary text-primary rounded-circle" style="width: 32px; height: 32px;">
					<i data-feather="user" style="width: 16px; height: 16px;"></i>
				</div>
				<div class="flex-grow-1">
					<div class="fw-800 text-dark small">My Profile</div>
				</div>
			</a>

			<div class="dropdown-divider my-2 mx-n2 opacity-5"></div>

			<a asp-area="" asp-controller="SenseiJapaneseSchool" asp-action="LogoutGoogle" class="dropdown-item d-flex align-items-center gap-3 py-2 px-3 rounded-3 text-danger mb-0 logout-item">
				<div class="d-flex align-items-center justify-content-center bg-soft-danger text-danger rounded-circle logout-icon-bg" style="width: 32px; height: 32px;">
					<i data-feather="log-out" style="width: 16px; height: 16px;"></i>
				</div>
				<div class="flex-grow-1">
					<div class="fw-800 small">Sign Out</div>
				</div>
				<i data-feather="chevron-right" style="width: 14px; height: 14px; opacity: 0.4;"></i>
			</a>
		</div>
	</div>
</li>
