<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Sensei Japanese Center</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #fff7f3;
        }

        .wrapper {
            width: 100%;
            background: #fff7f3;
        }

        .container {
            max-width: 600px;
            background: #ffffff;
        }

        .header {
            padding: 24px 16px;
            background: #fff7f3;
            text-align: center;
        }

        .logo {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #ff5a5f;
            color: #ffffff;
            font-weight: 700;
            font-size: 18px;
            line-height: 42px;
            margin: 0 auto 8px;
        }

        .title {
            margin: 0;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 16px;
            font-weight: 600;
            color: #222222;
        }

        .subtitle {
            margin: 4px 0 0;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 13px;
            color: #666666;
        }

        .body {
            padding: 28px 18px;
            text-align: center;
        }

        .hello {
            margin: 0 0 12px;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 15px;
            color: #222222;
        }

        .text-main {
            margin: 0 0 16px;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 14px;
            line-height: 1.6;
            color: #222222;
        }

        .text-secondary {
            margin: 0 0 22px;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 14px;
            line-height: 1.6;
            color: #666666;
        }

        .button {
            display: inline-block;
            padding: 12px 26px;
            background: #ff5a5f;
            color: #ffffff;
            text-decoration: none;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 14px;
            font-weight: 600;
            border-radius: 999px;
        }

        .footer {
            padding: 20px 16px;
            background: #fff7f3;
            text-align: center;
        }

        .footer-text {
            margin: 0 0 6px;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 12px;
            color: #666666;
        }

        .footer-contact {
            margin: 0;
            font-family: system-ui,Segoe UI,Arial,sans-serif;
            font-size: 12px;
            color: #666666;
        }
    </style>
</head>

<body>

    <table class="wrapper" cellpadding="0" cellspacing="0" role="presentation">
        <tr>
            <td align="center">

                @RenderBody()

            </td>
        </tr>
    </table>

</body>
</html>