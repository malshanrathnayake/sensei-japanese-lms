@using core_web.Helpers
@using System.Text.Json

@{
	Layout = null;
    var notificationsJson = TempData["Notifications"] as string;
}

<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<!-- Primary SEO -->
	<title>@ViewData["Title"] | SENSEI - Learning Management System</title>
	<meta name="description" content="@ViewData["MetaDescription"]" />
	<meta name="keywords" content="@ViewData["MetaKeyWords"]" />

	<link rel="preconnect" href="https://fonts.gstatic.com">
	<link rel="shortcut icon" href="~/theme/v1/img/photos/logo.PNG" />

	<link rel="canonical" href="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path" />

	<!-- Open Graph (Facebook / LinkedIn) -->
	<meta property="og:type" content="website">
	<meta property="og:title" content="@ViewData["Title"] | SENSEI LMS">
	<meta property="og:description" content="@ViewData["MetaDescription"]">
	<meta property="og:url" content="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path">
	<meta property="og:site_name" content="SENSEI">
	<meta property="og:image" content="https://www.senseijapanesecenter.com/theme/v1/img/photos/logo.PNG">

	<!-- Twitter Card -->
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:title" content="@ViewData["Title"] | SENSEI LMS">
	<meta name="twitter:description" content="@ViewData["MetaDescription"]">
	<meta name="twitter:image" content="https://www.senseijapanesecenter.com/theme/v1/img/photos/logo.PNG">

	<title>SENSEI | @ViewData["Title"]</title>

	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

	<link href="~/theme/v1/css/app.css" rel="stylesheet">
	<link href="~/css/custom.css" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@700;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
	<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

	<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

	<link href="~/lib/sweetalert2/sweetalert2.bundle.css" rel="stylesheet">
	<link href="~/lib/ladda/dist/ladda-themeless.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">

	<link href="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.10.0/dist/css/bootstrap-datepicker.min.css" rel="stylesheet">

	<style>
		body {
			font-family: 'Plus Jakarta Sans', sans-serif !important;
		}

		.sidebar-brand span {
			font-family: 'Noto Serif JP', serif !important;
		}

		/* Subtle Sakura ornament for Admin */
		.main::after {
			content: "";
			position: fixed;
			bottom: -50px;
			right: -50px;
			width: 300px;
			height: 300px;
			background-image: url('/theme/v1/img/photos/sakura.png');
			background-size: contain;
			background-repeat: no-repeat;
			opacity: 0.05;
			pointer-events: none;
			z-index: 0;
		}

		.card-title {
			font-weight: 800;
			letter-spacing: -0.02em;
			color: var(--primary) !important;
		}

		.sidebar-link {
			font-weight: 600;
		}
	</style>
</head>

<body>
	<div class="wrapper">
		
		<!-- sidebar -->
		@Html.RenderAction("AdminSidebar", "Layout", new { area = "" })

		<div class="main">
			
			<!-- header -->
			@Html.RenderAction("AdminPortalHeader", "Layout", new { area = "" })

			<div class="jp-watermark jp-pos-1">先生</div>
			<div class="jp-watermark jp-pos-2">日本語</div>

			<!-- body -->
			<main class="content">

				@RenderBody()

			</main>

			<!-- footer -->
			@Html.RenderAction("AdminPortalFooter", "Layout", new { area = "" })

		</div>

	</div>

	<!-- Core dependency -->
	<script src="~/lib/jquery/dist/jquery.min.js"></script>

	<!-- jQuery plugins that depend on jQuery -->
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
	<script src="~/lib/jquery-ajax-unobtrusive/dist/jquery.unobtrusive-ajax.min.js"></script>

	<!-- Bootstrap -->
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

	<!-- Site -->
	<script src="~/js/site.js"></script>

	<!-- UI / Icon libraries -->
	<script src="~/lib/feather/feather.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>

	<!-- Form / UX Enhancements -->
	<script src="~/lib/select2-inspinia/select2.full.min.js"></script>
	<script src="~/lib/sweetalert2/sweetalert2.bundle.js"></script>

	<!-- Loading / Button state -->
	<script src="~/lib/ladda/dist/spin.min.js"></script>
	<script src="~/lib/ladda/dist/ladda.min.js"></script>

	<!-- Your global helpers -->
	<script src="~/js/global-function.js"></script>

	<!-- Data Table -->
	<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
	<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

	<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.10.0/dist/js/bootstrap-datepicker.min.js"></script>

	<script>

		window.notyf = new Notyf({
			duration: 5000,
			dismissible: true,
			position: {
				x: 'right',
				y: 'top'
			},
			types: [
				{
					type: 'info',
					background: '#0dcaf0',
					icon: false
				},
				{
					type: 'warning',
					background: '#ffc107',
					icon: false
				},
				{
					type: 'success',
					background: '#2e7d32',
					icon: false
				},
				{
					type: 'error',
					background: '#D83236',
					icon: false
				}
			]
		});

		document.addEventListener("DOMContentLoaded", function () {

			if (window.feather) {
				feather.replace();
			}

			const notificationsJson = @Html.Raw(notificationsJson != null ? notificationsJson : "null");

			if (!notificationsJson || notificationsJson.length === 0) return;

			notificationsJson.forEach(n => {
				window.notyf.open({
					type: n.Type.toLowerCase(), // Notyf expects lowercase
					message: n.Message,
					duration: n.Duration,
					dismissible: n.Dismissible,
					position: {
						x: n.PositionX,
						y: n.PositionY
					}
				});
			});

		});
	</script>

	<!--SignalR Connections-->
	<script>

		$(document).ready(function () {
			updateAdminBadges();
			setInterval(updateAdminBadges, 60000); // Refresh every minute

			const notificationConnection = new signalR.HubConnectionBuilder()
				.withUrl("/hubs/notifications")
				.build();

			notificationConnection.on("ReceiveNotification", function (data) {

				popUpNotification('success', data.message);

                const date = new Date(data.createdAt);
                const timeStr = date.toLocaleTimeString("en-GB", { hour: '2-digit', minute: '2-digit' });
                const dateStr = date.toLocaleDateString("en-GB", { day: '2-digit', month: 'short', year: 'numeric' });

				const html = `
					<a href="#" class="list-group-item list-group-item-action border-0 py-3 px-4 usernotification-item" data-action-parameter="${data.encryptedKey}" style="transition: all 0.2s ease;">
						<div class="row g-0 align-items-center">
							<div class="col-2">
								<div class="bg-soft-warning p-2 rounded-3 text-warning d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
									<i data-feather="${data.icon || 'bell'}" style="width: 18px; height: 18px;"></i>
								</div>
							</div>
							<div class="col-10 ps-3">
								<div class="d-flex justify-content-between align-items-center mb-1">
									<span class="text-dark fw-800 small text-uppercase" style="letter-spacing: 0.02em;">${data.notificationType}</span>
									<span class="text-muted smaller fw-600" style="font-size: 0.65rem;">${timeStr}</span>
								</div>
								<div class="text-muted small fw-600 lh-sm">${data.message}</div>
								<div class="mt-1 text-muted smaller" style="font-size: 0.68rem; opacity: 0.7;">
									<i class="me-1" data-feather="calendar" style="width: 10px; height: 10px;"></i>
									${dateStr}
								</div>
							</div>
						</div>
					</a>
				`;

				$("#userNotificationlist").prepend(html);
                
                // Clear empty state if it exists
                $("#userNotificationlist .p-5.text-center").remove();

				if (window.feather) {
					feather.replace();
				}

				updateUserNotification();
				updateUserNotificationCount();

			});

			notificationConnection.start();

			updateUserNotification();

		});

		function formatDate(dateStr) {
			const d = new Date(dateStr);
			return d.toLocaleDateString("en-GB") + " " + d.toLocaleTimeString("en-GB", { hour: '2-digit', minute: '2-digit' });
		}
		function updateAdminBadges() {
			$.getJSON('/Layout/GetAdminActionCounts', function(data) {
				if (data.pendingRegistrations > 0) {
					$('#badge-pending-registration').text(data.pendingRegistrations).removeClass('d-none');
				} else {
					$('#badge-pending-registration').addClass('d-none');
				}

				if (data.pendingPayments > 0) {
					$('#badge-pending-payment').text(data.pendingPayments).removeClass('d-none');
				} else {
					$('#badge-pending-payment').addClass('d-none');
				}

				if (data.pendingLessonRequests > 0) {
					$('#badge-pending-lesson-request').text(data.pendingLessonRequests).removeClass('d-none');
				} else {
					$('#badge-pending-lesson-request').addClass('d-none');
				}
			});
		}

	</script>

	@await RenderSectionAsync("Scripts", required: false)

</body>

</html>